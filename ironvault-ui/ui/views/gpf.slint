import { Button, LineEdit, ScrollView } from "std-widgets.slint";
import { Theme, FluidButton } from "../theme.slint"; // Import FluidButton here

export struct GpfCaseDetails {
    regd_no: string,
    holder_name: string,
    series_id: string,
    account_no: string,
    balance: string,
    status: string
}

export component GpfFinalPaymentView inherits Rectangle {
    in-out property <string> active_schema_action;
    in-out property <string> op_status_msg;
    in-out property <bool> op_is_error;
    
    in-out property <string> op_regd_no;
    in-out property <string> op_series_id;
    in-out property <string> op_account_no;
    in-out property <string> op_gpf_new_status;
    in-out property <bool> gpf_case_found;
    in-out property <GpfCaseDetails> active_gpf_case;

    callback request_find_gpf_case(string);
    callback request_delete_full_case(string, string, string);
    callback request_delete_application(string);
    callback request_delete_precalc(string);
    callback request_update_gpf_status(string, string);
    callback request_delete_auth_reports(string);

    background: transparent;

    // Use a Z-Stack (overlapping rectangles) to allow items to fade over one another
    VerticalLayout {
        spacing: 12px; 
        padding: 0px;

        // Sub-Navigation Chips Menu
        HorizontalLayout {
            spacing: 8px;
            alignment: start;
            
            Button { 
                text: "🔍 Profile Acquisition Core"; 
                height: 32px;
                checked: root.active_schema_action == "gpffp_find";
                clicked => { root.active_schema_action = "gpffp_find"; } 
            }
            Button { 
                text: "🚨 Destructive Override Safehouse"; 
                height: 32px;
                checked: root.active_schema_action == "gpffp_clear";
                clicked => { root.active_schema_action = "gpffp_clear"; } 
            }
        }

        // Master View Container Frame
        Rectangle {
            vertical-stretch: 1;

            // =========================================================================
            // 🔍 VIEW 1: PROFILE ACQUISITION CORE (CROSS-FADING)
            // =========================================================================
            Rectangle {
                // Kinetic Fade Properties
                opacity: root.active_schema_action == "gpffp_find" ? 1.0 : 0.0;
                visible: self.opacity > 0.05; // Hide from hit-tests entirely when collapsed
                
                animate opacity { duration: 250ms; easing: ease-in-out; }

                VerticalLayout {
                    spacing: 12px;
                    
                    Rectangle {
                        background: Theme.bg-card; 
                        border-radius: 12px; 
                        border-width: 1px; 
                        border-color: Theme.border-color;
                        height: 100px; 
                        
                        VerticalLayout {
                            padding-left: 16px; padding-right: 16px; padding-top: 12px; padding-bottom: 12px;
                            spacing: 8px;
                            
                            Text { 
                                text: "GPF RELATIONAL ENCLAVE INQUIRY"; 
                                font-size: 12px; font-weight: 900; color: Theme.brand-primary; letter-spacing: 0.5px; 
                            }
                            
                            HorizontalLayout {
                                spacing: 12px; alignment: start;
                                
                                VerticalLayout { 
                                    spacing: 4px; width: 280px; 
                                    Text { text: "REGISTRATION INDEX KEY *"; font-size: 10px; font-weight: 800; color: Theme.text-muted; } 
                                    LineEdit { text <=> root.op_regd_no; placeholder_text: "Ex: 45102/FP"; height: 32px; } 
                                }
                                
                                VerticalLayout { 
                                    alignment: end; 
                                    Button { 
                                        text: "Scan Secure Ring"; height: 32px; 
                                        clicked => { root.request_find_gpf_case(root.op_regd_no); } 
                                    } 
                                }
                            }
                        }
                    }

                    if (root.gpf_case_found) : Rectangle {
                        background: #10b98106; border-radius: 12px; border-width: 1px; border-color: #10b98133;
                        VerticalLayout {
                            padding: 14px; spacing: 10px;
                            HorizontalLayout {
                                alignment: space-between;
                                VerticalLayout {
                                    spacing: 2px;
                                    Text { text: "Active Ledger Match Verified"; font-size: 13px; font-weight: 800; color: Theme.text-primary; }
                                    Text { text: "Cryptographic runtime session maps bound smoothly."; font-size: 11px; color: Theme.text-secondary; }
                                }
                                Rectangle { width: 8px; height: 8px; border-radius: 4px; background: Theme.brand-success; y: 4px; }
                            }
                            Rectangle { height: 1px; background: Theme.border-color; opacity: 0.15; }
                            HorizontalLayout {
                                spacing: 28px; alignment: start; 
                                VerticalLayout { spacing: 4px; width: 200px; Text { text: "ACCOUNT HOLDER NAME"; font-size: 9px; color: Theme.text-muted; } Text { text: root.active_gpf_case.holder_name; font-size: 13px; font-weight: 700; color: Theme.text-primary; } }
                                VerticalLayout { spacing: 4px; width: 90px; Text { text: "SERIES PREFIX"; font-size: 9px; color: Theme.text-muted; } Text { text: root.active_gpf_case.series_id; font-size: 13px; font-family: "Consolas"; font-weight: 700; color: Theme.brand-warning; } }
                                VerticalLayout { spacing: 4px; width: 120px; Text { text: "LEDGER ACCOUNT NO"; font-size: 9px; color: Theme.text-muted; } Text { text: root.active_gpf_case.account_no; font-size: 13px; font-family: "Consolas"; color: Theme.text-primary; } }
                                VerticalLayout { spacing: 4px; width: 140px; Text { text: "CLOSING VALUATION"; font-size: 9px; color: Theme.text-muted; } Text { text: "₹ " + root.active_gpf_case.balance; font-size: 14px; font-weight: 900; color: Theme.brand-primary; } }
                            }
                        }
                    }
                }
            }

            // =========================================================================
            // 🚨 VIEW 2: DESTRUCTIVE OVERRIDE SAFEHOUSE (CROSS-FADING)
            // =========================================================================
            Rectangle {
                // Kinetic Fade Properties
                opacity: root.active_schema_action == "gpffp_clear" ? 1.0 : 0.0;
                visible: self.opacity > 0.05;
                
                animate opacity { duration: 250ms; easing: ease-in-out; }

                Rectangle {
                    background: #ef444403; border-radius: 12px; border-width: 1px; border-color: #ef444426;
                    VerticalLayout {
                        padding: 16px; spacing: 12px;
                        VerticalLayout {
                            spacing: 2px;
                            Text { text: "CRITICAL REGULATORY ADMINISTRATIVE INTERFACE"; font-size: 12px; font-weight: 900; color: Theme.brand-danger; letter-spacing: 0.5px; }
                            Text { text: "Cascading deletions directly modify layout sectors. Provide explicit targets before execution."; font-size: 11px; color: Theme.text-secondary; }
                        }
                        Rectangle { height: 1px; background: Theme.border-color; opacity: 0.1; }
                        HorizontalLayout {
                            spacing: 12px; alignment: start;
                            VerticalLayout { spacing: 4px; width: 180px; Text { text: "APPLICATION / REGD NO"; font-size: 10px; color: Theme.text-muted; } LineEdit { text <=> root.op_regd_no; placeholder_text: "Ex: 45102/FP"; height: 30px; } }
                            VerticalLayout { spacing: 4px; width: 140px; Text { text: "SERIES PREFIX CODE"; font-size: 10px; color: Theme.text-muted; } LineEdit { text <=> root.op_series_id; placeholder_text: "Ex: EDN"; height: 30px; } }
                            VerticalLayout { spacing: 4px; width: 180px; Text { text: "ACCOUNT NO REFERENCE"; font-size: 10px; color: Theme.text-muted; } LineEdit { text <=> root.op_account_no; placeholder_text: "Ex: 12435"; height: 30px; } }
                        }
                        Rectangle { height: 1px; background: Theme.border-color; opacity: 0.1; }
                        
                        // Integrated our new premium FluidButtons for tactile interactions!
                        GridLayout {
                            spacing: 10px;
                            Row {
                                FluidButton { 
                                    text: "💥 Drop Full Settlement Profile"; is_destructive: true;
                                    clicked => { root.request_delete_full_case(root.op_regd_no, root.op_series_id, root.op_account_no); } 
                                }
                                FluidButton { 
                                    text: "🗑️ Purge Application Row Element"; is_destructive: true;
                                    clicked => { root.request_delete_application(root.op_regd_no); } 
                                }
                            }
                            Row {
                                FluidButton { 
                                    text: "📊 Flush Pre-Calculations Cluster"; 
                                    clicked => { root.request_delete_precalc(root.op_regd_no); } 
                                }
                                FluidButton { 
                                    text: "📜 Drop Signed Authority Certificates"; 
                                    clicked => { root.request_delete_auth_reports(root.op_regd_no); } 
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}