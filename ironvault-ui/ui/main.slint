                                        op_status_msg <=> root.op_status_msg;
                                        op_is_error <=> root.op_is_error;
                                        vlcs_ddo_code <=> root.vlcs_ddo_code;
                                        vlcs_emp_code <=> root.vlcs_emp_code;
                                        vlcs_emp_mobile <=> root.vlcs_emp_mobile;
                                        request_vlcs_get_ddo(c) => { root.request_vlcs_get_ddo(c); }
                                        request_vlcs_update_ddo(c) => { root.request_vlcs_update_ddo(c); }
                                        request_vlcs_get_emp(c) => { root.request_vlcs_get_emp(c); }
                                        request_vlcs_update_emp(c, m) => { root.request_vlcs_update_emp(c, m); }
                                    }
                                    if (root.op_target_schema == "pendak" && root.schema_access.pendak): PenDakView {
