import { Button, LineEdit } from "std-widgets.slint";
import { Theme } from "../theme.slint";

export component VlcsComputerizedView inherits Rectangle {
    in-out property <string> active_schema_action;
    in-out property <string> op_status_msg;
    in-out property <bool> op_is_error;
    
    in-out property <string> vlcs_ddo_code;
    in-out property <string> vlcs_emp_code;
    in-out property <string> vlcs_emp_mobile;

    callback request_vlcs_get_ddo(string);
    callback request_vlcs_update_ddo(string);
    callback request_vlcs_get_emp(string);
    callback request_vlcs_update_emp(string, string);

    background: transparent;

    VerticalLayout {
        spacing: 24px;
        HorizontalLayout {
            spacing: 12px;
            Button { text: "🏢 DDO Operations Console"; clicked => { root.active_schema_action = "vlcs_ddo"; } }
            Button { text: "👤 Employee Operations Node"; clicked => { root.active_schema_action = "vlcs_emp"; } }
        }

        Rectangle {
            background: Theme.bg-card; border-radius: 16px; border-width: 1px; border-color: Theme.border-color;
            VerticalLayout {
                padding: 24px; spacing: 20px;
                if (root.active_schema_action == "vlcs_ddo") : VerticalLayout {
                    spacing: 16px;
                    Text { text: "DRAWING AND DISBURSING OFFICER REGISTRY CONFIGURATION"; font-size: 13px; font-weight: 900; color: Theme.brand-primary; }
                    HorizontalLayout {
                        spacing: 16px; alignment: start;
                        VerticalLayout { spacing: 6px; width: 280px; Text { text: "DDO ALLOCATION CODE *"; font-size: 11px; color: Theme.text-muted; } LineEdit { text <=> root.vlcs_ddo_code; placeholder_text: "e.g. WBGTRD001"; height: 36px; } }
                    }
                    HorizontalLayout {
                        spacing: 12px;
                        Button { text: "Query Allocation Matrix"; clicked => { root.request_vlcs_get_ddo(root.vlcs_ddo_code); } }
                        Button { text: "Commit Re-Allocation Pass"; clicked => { root.request_vlcs_update_ddo(root.vlcs_ddo_code); } }
                    }
                }

                if (root.active_schema_action == "vlcs_emp") : VerticalLayout {
                    spacing: 16px;
                    Text { text: "EMPLOYEE TELEMETRY AND FIELD RECORD METRICS"; font-size: 13px; font-weight: 900; color: Theme.brand-primary; }
                    HorizontalLayout {
                        spacing: 16px;
                        VerticalLayout { spacing: 6px; width: 240px; Text { text: "HRMS EMPLOYEE CODE *"; font-size: 11px; color: Theme.text-muted; } LineEdit { text <=> root.vlcs_emp_code; placeholder_text: "e.g. 20241105"; height: 36px; } }
                        VerticalLayout { spacing: 6px; width: 240px; Text { text: "TARGET TELEPHONE PHONE FIELD *"; font-size: 11px; color: Theme.text-muted; } LineEdit { text <=> root.vlcs_emp_mobile; placeholder_text: "e.g. +91XXXXXXXXXX"; height: 36px; } }
                    }
                    HorizontalLayout {
                        spacing: 12px;
                        Button { text: "Query Core Fields"; clicked => { root.request_vlcs_get_emp(root.vlcs_emp_code); } }
                        Button { text: "Update Field Metrics"; clicked => { root.request_vlcs_update_emp(root.vlcs_emp_code, root.vlcs_emp_mobile); } }
                    }
                }
            }
        }
    }
}