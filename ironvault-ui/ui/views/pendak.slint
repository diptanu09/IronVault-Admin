import { Button, LineEdit, ScrollView } from "std-widgets.slint";
import { Theme } from "../theme.slint";

export struct DakRecipientDetail {
    addressee: string,
    barcode: string,
    sent_by: string,
    service_book: string
}

export component PenDakView inherits Rectangle {
    in-out property <string> active_schema_action;
    in-out property <string> op_status_msg;
    in-out property <bool> op_is_error;
    
    in-out property <string> entry_app_num;
    in-out property <string> entry_letter_no;
    in-out property <string> entry_section;
    in-out property <string> entry_subject;
    in-out property <string> entry_no_of_copies;
    in-out property <string> find_app_num;
    in-out property <string> edit_app_num;
    in-out property <string> edit_section;
    in-out property <string> edit_subject;
    in-out property <string> letter_app_num;
    in-out property <string> letter_letter_no;
    in-out property <string> letter_section;
    in-out property <string> letter_subject;
    in-out property <string> letter_no_of_copies;
    
    in-out property <string> dak_ppo;
    in-out property <string> dak_fppo;
    in-out property <string> dak_gpo;
    in-out property <string> dak_cpo;
    in-out property <string> dak_adr_1;
    in-out property <string> dak_bar_1;
    in-out property <string> dak_sent_1;
    in-out property <string> dak_adr_2;
    in-out property <string> dak_bar_2;
    in-out property <string> dak_sent_2;
    in-out property <string> dak_adr_3;
    in-out property <string> dak_bar_3;
    in-out property <string> dak_sent_3;
    
    in-out property <bool> dak_case_found;
    in-out property <string> view_dak_letter;
    in-out property <string> view_dak_subject;
    in-out property <string> view_dak_section;
    in-out property <string> dak_corr_date;

    callback request_find_pension_dak_meta(string);
    callback request_submit_outward_dak();
    callback request_find_outward_dak(string);
    callback request_update_outward_dak();
    callback request_submit_correspondence();

    background: transparent;

    VerticalLayout {
        spacing: 20px;
        
        // Ribbon Navigation
        HorizontalLayout {
            spacing: 10px; //wrap: word-wrap;
            Button { text: "📥 Entry Outward Case"; checked: root.active_schema_action == "pendak_entry"; clicked => { root.active_schema_action = "pendak_entry"; } }
            Button { text: "🔍 Find Outward Case"; checked: root.active_schema_action == "pendak_find"; clicked => { root.active_schema_action = "pendak_find"; } }
            Button { text: "📝 Edit/Update Outward"; checked: root.active_schema_action == "pendak_edit"; clicked => { root.active_schema_action = "pendak_edit"; } }
            Button { text: "🔗 Outward Letter Link"; checked: root.active_schema_action == "pendak_letter"; clicked => { root.active_schema_action = "pendak_letter"; } }
        }

        Rectangle {
            background: Theme.bg-card; border-radius: 16px; border-width: 1px; border-color: Theme.border-color; vertical-stretch: 1;
            VerticalLayout {
                padding: 24px;
            
                if (root.active_schema_action == "pendak_entry") : ScrollView {
                    VerticalLayout {
                        spacing: 16px;
                        Text { text: "LOG NEW OUTWARD DAK DIARY ENVELOPE RECORD"; font-size: 13px; font-weight: 900; color: Theme.brand-primary; letter-spacing: 0.5px; }
                        
                        HorizontalLayout {
                            spacing: 16px;
                            VerticalLayout { spacing: 6px; width: 240px; Text { text: "APPLICATION NO *"; font-size: 11px; color: Theme.text-muted; } LineEdit { text <=> root.entry_app_num; placeholder_text: "e.g. 104250"; height: 36px; edited => { root.request_find_pension_dak_meta(root.entry_app_num); } } }
                            VerticalLayout { spacing: 6px; width: 240px; Text { text: "OUTWARD LETTER NO *"; font-size: 11px; color: Theme.text-muted; } LineEdit { text <=> root.entry_letter_no; placeholder_text: "e.g. DAK-2026-X"; height: 36px; } }
                        }
                        
                        // Auto-Fetched Core Pension Authorities Panel Mapping
                        Rectangle {
                            background: #1118274D; border-radius: 8px; height: 60px;
                            HorizontalLayout {
                                padding: 12px; spacing: 20px;
                                VerticalLayout { spacing: 2px; Text { text: "PPO NUMBER"; font-size: 9px; color: Theme.text-muted; } Text { text: root.dak_ppo == "" ? "Awaiting Input..." : root.dak_ppo; font-size: 13px; font-weight: 700; } }
                                VerticalLayout { spacing: 2px; Text { text: "FPPO NUMBER"; font-size: 9px; color: Theme.text-muted; } Text { text: root.dak_fppo == "" ? "Awaiting Input..." : root.dak_fppo; font-size: 13px; font-weight: 700; } }
                                VerticalLayout { spacing: 2px; Text { text: "GPO AUTHORITY"; font-size: 9px; color: Theme.text-muted; } Text { text: root.dak_gpo == "" ? "N/A" : root.dak_gpo; font-size: 13px; } }
                                VerticalLayout { spacing: 2px; Text { text: "CPO AUTHORITY"; font-size: 9px; color: Theme.text-muted; } Text { text: root.dak_cpo == "" ? "N/A" : root.dak_cpo; font-size: 13px; } }
                            }
                        }

                        HorizontalLayout {
                            spacing: 16px;
                            VerticalLayout { spacing: 6px; width: 240px; Text { text: "ROUTING SECTION MATRIX *"; font-size: 11px; color: Theme.text-muted; } LineEdit { text <=> root.entry_section; placeholder_text: "e.g. Pension-3"; height: 36px; } }
                            VerticalLayout { spacing: 6px; horizontal-stretch: 1; Text { text: "COMMUNICATION SUBJECT OVERVIEW *"; font-size: 11px; color: Theme.text-muted; } LineEdit { text <=> root.entry_subject; placeholder_text: "Summary of files forwarded..."; height: 36px; } }
                        }

                        HorizontalLayout {
                            spacing: 16px;
                            VerticalLayout { spacing: 6px; width: 120px; Text { text: "NO OF COPIES"; font-size: 11px; color: Theme.text-muted; } LineEdit { text <=> root.entry_no_of_copies; height: 36px; } }
                        }

                        // Recipient Rows Framework Layout Block Matrix
                        Text { text: "RECIPIENT FORENSICS DISPATCH PROFILES"; font-size: 12px; font-weight: 800; color: Theme.brand-warning; }
                        
                        VerticalLayout {
                            spacing: 10px;
                            Rectangle {
                                background: #FFFFFF01; border-radius: 8px; border-width: 1px; border-color: Theme.border-color; height: 50px;
                                HorizontalLayout {
                                    padding-left: 12px; padding-right: 12px; spacing: 16px;
                                    Text { text: "1"; font-weight: 900; color: Theme.brand-primary; vertical-alignment: center; }
                                    LineEdit { text <=> root.dak_adr_1; placeholder_text: "Recipient Addressee 1 Destination"; horizontal-stretch: 1; height: 32px; y: 9px; }
                                    LineEdit { text <=> root.dak_bar_1; placeholder_text: "Speed Post Barcode / Tracking Index"; width: 260px; height: 32px; y: 9px; }
                                    LineEdit { text <=> root.dak_sent_1; width: 140px; height: 32px; y: 9px; }
                                }
                            }
                            
                            if (root.entry_no_of_copies == "2" || root.entry_no_of_copies == "3") : Rectangle {
                                background: #FFFFFF01; border-radius: 8px; border-width: 1px; border-color: Theme.border-color; height: 50px;
                                HorizontalLayout {
                                    padding-left: 12px; padding-right: 12px; spacing: 16px;
                                    Text { text: "2"; font-weight: 900; color: Theme.brand-primary; vertical-alignment: center; }
                                    LineEdit { text <=> root.dak_adr_2; placeholder_text: "Recipient Addressee 2 Destination"; horizontal-stretch: 1; height: 32px; y: 9px; }
                                    LineEdit { text <=> root.dak_bar_2; placeholder_text: "Speed Post Barcode / Tracking Index"; width: 260px; height: 32px; y: 9px; }
                                    LineEdit { text <=> root.dak_sent_2; width: 140px; height: 32px; y: 9px; }
                                }
                            }

                            if (root.entry_no_of_copies == "3") : Rectangle {
                                background: #FFFFFF01; border-radius: 8px; border-width: 1px; border-color: Theme.border-color; height: 50px;
                                HorizontalLayout {
                                    padding-left: 12px; padding-right: 12px; spacing: 16px;
                                    Text { text: "3"; font-weight: 900; color: Theme.brand-primary; vertical-alignment: center; }
                                    LineEdit { text <=> root.dak_adr_3; placeholder_text: "Recipient Addressee 3 Destination"; horizontal-stretch: 1; height: 32px; y: 9px; }
                                    LineEdit { text <=> root.dak_bar_3; placeholder_text: "Speed Post Barcode / Tracking Index"; width: 260px; height: 32px; y: 9px; }
                                    LineEdit { text <=> root.dak_sent_3; width: 140px; height: 32px; y: 9px; }
                                }
                            }
                        }

                        Button { text: "Commit Immutably to Diary Ring"; height: 40px; clicked => { root.request_submit_outward_dak(); } }
                    }
                }
            
                if (root.active_schema_action == "pendak_find") : VerticalLayout {
                    spacing: 16px;
                    Text { text: "QUERY METADATA CORRESPONDENCE TRACKER ARCHIVE"; font-size: 13px; font-weight: 900; color: Theme.brand-primary; }
                    HorizontalLayout {
                        spacing: 16px; alignment: start;
                        VerticalLayout { spacing: 4px; width: 340px; LineEdit { text <=> root.find_app_num; placeholder_text: "Enter verification app sequence token..."; height: 36px; } }
                        VerticalLayout { alignment: end; Button { text: "Locate Transaction"; height: 36px; clicked => { root.request_find_outward_dak(root.find_app_num); } } }
                    }
                    
                    if (root.dak_case_found) : Rectangle {
                        background: #11182766; border-radius: 12px; border-width: 1px; border-color: Theme.border-color;
                        VerticalLayout {
                            padding: 20px; // FIXED: Moved padding to Layout element
                            spacing: 14px;
                            Text { text: "Matched Enclave Case Entry Records"; font-size: 14px; font-weight: 800; color: Theme.brand-warning; }
                            
                            // FIXED: Correct layout tag designation
                            GridLayout {
                                spacing: 12px;
                                Row { Text { text: "Letter Reference Number:"; color: Theme.text-muted; } Text { text: root.view_dak_letter; font-weight: 700; color: Theme.text-primary; } }
                                Row { Text { text: "Handling Department Section:"; color: Theme.text-muted; } Text { text: root.view_dak_section; font-family: "Consolas"; } }
                                Row { Text { text: "Correspondence Logging Date:"; color: Theme.text-muted; } Text { text: root.dak_corr_date; } }
                                Row { Text { text: "Communication Subject Matter:"; color: Theme.text-muted; } Text { text: root.view_dak_subject; wrap: word-wrap; } }
                            }
                        }
                    }
                }

                if (root.active_schema_action == "pendak_edit") : VerticalLayout {
                    spacing: 16px;
                    Text { text: "AMEND EXISTENT OUTWARD DATA COEFFICIENTS"; font-size: 13px; font-weight: 900; color: Theme.brand-primary; }
                    HorizontalLayout {
                        spacing: 16px;
                        VerticalLayout { spacing: 6px; width: 220px; Text { text: "TARGET APP NO *"; font-size: 11px; color: Theme.text-muted; } LineEdit { text <=> root.edit_app_num; height: 36px; } }
                        VerticalLayout { spacing: 6px; width: 220px; Text { text: "RE-ROUTE NEW SECTION *"; font-size: 11px; color: Theme.text-muted; } LineEdit { text <=> root.edit_section; height: 36px; } }
                        VerticalLayout { spacing: 6px; horizontal-stretch: 1; Text { text: "REVISED SUBJECT MATTER *"; font-size: 11px; color: Theme.text-muted; } LineEdit { text <=> root.edit_subject; height: 36px; } }
                    }
                    Rectangle { height: 8px; }
                    Button { text: "Apply Amends Pass Over Target Record"; height: 38px; clicked => { root.request_update_outward_dak(); } }
                }

                if (root.active_schema_action == "pendak_letter") : VerticalLayout {
                    spacing: 16px;
                    Text { text: "LINK INTER-DEPARTMENTAL REPLIES & CORRESPONDENCE"; font-size: 13px; font-weight: 900; color: Theme.brand-primary; }
                    HorizontalLayout {
                        spacing: 16px;
                        VerticalLayout { spacing: 6px; width: 220px; Text { text: "PARENT APP NO *"; font-size: 11px; color: Theme.text-muted; } LineEdit { text <=> root.letter_app_num; height: 36px; } }
                        VerticalLayout { spacing: 6px; width: 220px; Text { text: "INCOMING LETTER REFERENCE *"; font-size: 11px; color: Theme.text-muted; } LineEdit { text <=> root.letter_letter_no; height: 36px; } }
                    }
                    HorizontalLayout {
                        spacing: 16px;
                        VerticalLayout { spacing: 6px; width: 220px; Text { text: "HANDLING SECTION *"; font-size: 11px; color: Theme.text-muted; } LineEdit { text <=> root.letter_section; height: 36px; } }
                        VerticalLayout { spacing: 6px; horizontal-stretch: 1; Text { text: "SUBJECT REMARKS *"; font-size: 11px; color: Theme.text-muted; } LineEdit { text <=> root.letter_subject; height: 36px; } }
                    }
                    Rectangle { height: 8px; }
                    Button { text: "Link Correspondence Document Component"; height: 38px; clicked => { root.request_submit_correspondence(); } }
                }
            }
        }
    }
}