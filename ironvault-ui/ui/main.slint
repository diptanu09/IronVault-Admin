// Master window with sidebar + content router
// Main entry point for the Slint UI

import { Button, LineEdit, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { LoginView } from "views/login.slint";

export component AppWindow inherits Window {
    title: "IRONVAULT // ADMINISTRATIVE CONTROL TERMINAL";
    width: 1024px;
    height: 720px;
    
    // Core Application State Linkage
    in-out property <bool> is_logged_in: false;
    in-out property <string> login_error: "";
    in-out property <string> hwid_string: "HWID: FETCHING...";
    
    in-out property <string> current_user_name: "GUEST";
    in-out property <string> current_user_role: "UNAUTHORIZED";
    in-out property <string> last_login: "NEVER";

    // Navigation State
    in-out property <string> active_tab: "overview";

    // Event Relays Upstream to Rust Loop
    callback request_authentication(string, string);
    callback request_registration(string, string, string);

    background: #0B0F19;

    HorizontalBox {
        spacing: 0;
        padding: 0;

        // SIDEBAR NAVIGATION MATRIX (Only visible when logged in)
        if root.is_logged_in : Rectangle {
            width: 240px;
            background: #111827;
            border-width: 1px;
            border-color: #1F2937;

            VerticalBox {
                padding: 20px;
                spacing: 20px;
                alignment: start;

                // Application Header Branding
                VerticalBox {
                    spacing: 4px;
                    Text { text: "IRONVAULT CORE"; font-size: 18px; font-weight: 800; color: #38BDF8; }
                    Text { text: "Admin Infrastructure v0.1.0"; font-size: 10px; color: #6B7280; }
                }

                Rectangle { height: 2px; background: #1F2937; }

                // User Identity Widget
                VerticalBox {
                    spacing: 5px;
                    Text { text: "OPERATOR PROFILE:"; font-size: 10px; color: #9CA3AF; font-weight: 700; }
                    Text { text: root.current_user_name; font-size: 14px; font-weight: 600; color: #F3F4F6; }
                    Text { text: "Role: " + root.current_user_role; font-size: 11px; color: #10B981; }
                }

                Rectangle { height: 2px; background: #1F2937; }

                // Interactive Menu Tab Selectors
                Button { 
                    text: "📊 System Overview"; 
                    clicked => { root.active_tab = "overview"; }
                }
                Button { 
                    text: "➕ Onboard Operator"; 
                    clicked => { root.active_tab = "registration"; }
                }

                Rectangle { vertical-stretch: 1; } 

                // Security Status Stamp footer
                VerticalBox {
                    spacing: 4px;
                    Text { text: "SECURITY SIGNATURE:"; font-size: 9px; color: #4B5563; font-weight: 700; }
                    Text { text: root.hwid_string; font-size: 9px; color: #6B7280; wrap: word-wrap; }
                }
            }
        }

        // MAIN CONTENT CANVAS VIEW AREA
        Rectangle {
            horizontal-stretch: 1;
            
            if !root.is_logged_in : LoginView {
                error_message: root.login_error;
                login_requested(user, pass) => { root.request_authentication(user, pass); }
            }

            if root.is_logged_in : VerticalBox {
                padding: 40px;
                spacing: 25px;

                // DYNAMIC VIEW 1: SYSTEM OVERVIEW PANEL
                if root.active_tab == "overview" : VerticalBox {
                    spacing: 20px;
                    
                    VerticalBox {
                        spacing: 5px;
                        Text { text: "SYSTEM OPERATIONAL OVERVIEW"; font-size: 22px; font-weight: 800; color: #FFFFFF; }
                        Text { text: "Live node diagnostics connected to database cluster AsstPro"; font-size: 13px; color: #9CA3AF; }
                    }

                    // Stat Metrics Grid Row
                    HorizontalBox {
                        spacing: 20px;
                        
                        Rectangle {
                            height: 100px;
                            background: #111827;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: #1F2937;
                            VerticalBox {
                                padding: 15px; alignment: center;
                                Text { text: "DB MATRIX CONNECTION"; font-size: 11px; color: #9CA3AF; font-weight: 700; }
                                Text { text: "ONLINE // SECURE"; font-size: 18px; color: #10B981; font-weight: 800; }
                            }
                        }

                        Rectangle {
                            height: 100px;
                            background: #111827;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: #1F2937;
                            VerticalBox {
                                padding: 15px; alignment: center;
                                Text { text: "CURRENT SESSION FOOTPRINT"; font-size: 11px; color: #9CA3AF; font-weight: 700; }
                                Text { text: root.last_login; font-size: 12px; color: #38BDF8; font-weight: 600; wrap: word-wrap; }
                            }
                        }
                    }

                    // System Operational Welcome Display Card
                    Rectangle {
                        background: #1E293B;
                        border-radius: 8px;
                        
                        // FIXED: Replaced 'padding: 20px' configuration with structured layout internals
                        VerticalBox {
                            padding-left: 20px;
                            padding-right: 20px;
                            padding-top: 20px;
                            padding-bottom: 20px;
                            spacing: 10px;
                            Text { text: "Welcome Back, Authorized Operator."; font-size: 16px; font-weight: 700; color: #38BDF8; }
                            Text { 
                                text: "The core database abstraction layer has loaded successfully. All access queries and actions performed within this panel will be appended directly to the physical system audit sequence trail table schema logs."; 
                                font-size: 13px; 
                                color: #E2E8F0; 
                                wrap: word-wrap; 
                            }
                        }
                    }
                }

                // DYNAMIC VIEW 2: ACCOUNT MANAGEMENT ONBOARDING PANEL
                if root.active_tab == "registration" : VerticalBox {
                    spacing: 20px;
                    alignment: start;

                    VerticalBox {
                        spacing: 5px;
                        Text { text: "SECURE OPERATOR ONBOARDING ENGINE"; font-size: 22px; font-weight: 800; color: #FFFFFF; }
                        Text { text: "Provision new credential records directly into the ironvault.users schema cluster"; font-size: 13px; color: #9CA3AF; }
                    }

                    Rectangle {
                        width: 500px;
                        background: #111827;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: #1F2937;
                        
                        VerticalBox {
                            padding: 30px;
                            spacing: 15px;

                            Text { text: root.login_error == "" ? "Fill out registration parameters:" : root.login_error; color: root.login_error == "Account Registered Successfully! Toggle view to sign in." ? #10B981 : #EF4444; font-size: 13px; }

                            VerticalBox {
                                spacing: 5px;
                                Text { text: "New Username"; color: #9CA3AF; font-size: 12px; }
                                reg_user := LineEdit { placeholder-text: "e.g. Operator_Delta"; }
                            }

                            VerticalBox {
                                spacing: 5px;
                                Text { text: "Secure Passcode"; color: #9CA3AF; font-size: 12px; }
                                reg_pass := LineEdit { input-type: password; placeholder-text: "••••••••"; }
                            }

                            VerticalBox {
                                spacing: 5px;
                                Text { text: "System Permission Level Role"; color: #9CA3AF; font-size: 12px; }
                                reg_role := LineEdit { text: "Operator"; placeholder-text: "SuperAdmin, Admin, Operator, Viewer"; }
                            }

                            Rectangle { height: 10px; }

                            Button {
                                text: "COMMIT OPERATOR ENTRY TO CLUSTER";
                                clicked => { 
                                    root.request_registration(reg_user.text, reg_pass.text, reg_role.text);
                                    reg_user.text = "";
                                    reg_pass.text = "";
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}