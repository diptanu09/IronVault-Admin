// Master window with sidebar + content router
// Main entry point for the Slint UI

import { Sidebar } from "components/sidebar.slint";
import { TopBar } from "components/topbar.slint";
import { LoginView } from "views/login.slint";
import { RegisterView } from "views/register.slint";
import { DashboardView } from "views/dashboard.slint";

export component MainWindow {
    width: 1400px;
    height: 900px;
    background: @linear-gradient(180deg, #0a0e27 0%, #1a1f3a 100%);
    
    // Properties exposed to Rust
    property <string> app_version: "1.0.0";
    property <string> copyright_text: "© 2024 IronVault";
    property <string> current_user: "";
    property <string> user_role: "";
    property <string> current_view: "login"; // login, register, dashboard
    property <string> error_message: "";
    property <string> notification: "";
    property <string> login_error: "";
    
    // Callbacks for Rust
    callback login_clicked(string, string); // username, password
    callback register_clicked(string, string, string); // name, email, password
    callback logout_clicked();
    callback navigate_view(string);
    
    // Main horizontal layout
    HorizontalLayout {
        // Sidebar (only visible when logged in)
        if current_user != "" {
            Sidebar {
                app_version: root.app_version;
                copyright_text: root.copyright_text;
                current_view: root.current_view;
                navigate_view(view) => {
                    root.current_view = view;
                    root.navigate_view(view);
                }
                logout => {
                    root.logout_clicked();
                }
            }
        }
        
        // Content area
        VerticalLayout {
            spacing: 0;
            
            // Top bar (only visible when logged in)
            if current_user != "" {
                TopBar {
                    user_name: root.current_user;
                    user_role: root.user_role;
                    logout => {
                        root.logout_clicked();
                    }
                }
            }
            
            // Main content router
            VerticalLayout {
                if current_view == "login" {
                    LoginView {
                        login_clicked(username, password) => {
                            root.login_clicked(username, password);
                        }
                        navigate_register => {
                            root.current_view = "register";
                        }
                    }
                } else if current_view == "register" {
                    RegisterView {
                        register_clicked(name, email, password) => {
                            root.register_clicked(name, email, password);
                        }
                        navigate_login => {
                            root.current_view = "login";
                        }
                    }
                } else if current_view == "dashboard" {
                    DashboardView {
                        // Pass any needed data to dashboard
                    }
                }
            }
            
            // Error notification
            if error_message != "" {
                Rectangle {
                    background: #d32f2f;
                    height: 40px;
                    Text {
                        text: root.error_message;
                        color: white;
                        vertical_alignment: center;
                        horizontal_alignment: center;
                    }
                }
            }
        }
    }
}
