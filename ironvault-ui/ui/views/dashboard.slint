// Dashboard view - Primary data metrics and information

import { Theme } from "theme.slint";

export component DashboardView {
    background: Theme.bg_primary;
    
    VerticalLayout {
        spacing: Theme.spacing_lg;
        padding: Theme.spacing_lg;
        
        // Dashboard Title
        Text {
            text: "Dashboard";
            color: Theme.primary;
            font_size: Theme.font_size_2xlarge;
            font_weight: 900;
            letter_spacing: 1px;
        }
        
        // Metrics Grid
        HorizontalLayout {
            spacing: Theme.spacing_lg;
            
            // Active Users Card
            Rectangle {
                background: Theme.bg_secondary;
                border_radius: Theme.radius_lg;
