// Master window with sidebar + content router
// Main entry point for the Slint UI

import { DashboardView } from "views/dashboard.slint";
import { LoginView } from "views/login.slint";
import { HorizontalBox, VerticalBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "IronVault Control Center";
    width: 1100px;
    height: 700px;
    background: #0B0F19; 
    
    in-out property <bool> is_logged_in: false;
    in-out property <string> current_user_name: "Guest";
    in-out property <string> current_user_role: "Unverified";
    in-out property <string> last_login: "--";
    in-out property <string> hwid_string: "HWID: LOADING...";
    in-out property <string> login_error: "";
    
    callback request_authentication(string, string);
    callback request_registration(string, string, string); // Add this callback definition

    if !is_logged_in : LoginView {
    error_message: root.login_error;
    login_requested(user, pass) => { root.request_authentication(user, pass); }
    registration_requested(user, pass, role) => { root.request_registration(user, pass, role); } // Bind it here
    }
    
    if is_logged_in : HorizontalBox {
        padding: 0px;
        spacing: 0px;
        
        // Sidebar Navigation Container
        Rectangle {
            width: 250px;
            background: #111827;
            
            // Replaced border-right-width with an explicit divider line
            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                height: parent.height;
                background: #1F2937;
            }
            
            VerticalBox {
                padding: 20px;
                spacing: 15px;
                
                Text { text: "IRONVAULT"; font-size: 24px; font-weight: 800; color: #38BDF8; }
                Text { text: "v2.1.0-ENTERPRISE"; font-size: 10px; color: #6B7280; }
                Text { text: root.hwid_string; font-size: 9px; color: #4B5563; }
                
                Rectangle { height: 20px; } 
                
                Rectangle { height: 40px; background: #1E293B; border-radius: 6px; Text { text: "Dashboard"; color: white; x: 15px; vertical-alignment: center;} }
                Rectangle { height: 40px; Text { text: "Database Sync"; color: #9CA3AF; x: 15px; vertical-alignment: center;} }
                Rectangle { height: 40px; Text { text: "System Audit Logs"; color: #9CA3AF; x: 15px; vertical-alignment: center;} }
                
                Rectangle {} // Pushes copyright to bottom
                
                Text { text: "© 2026 IronVault Systems"; font-size: 10px; color: #4B5563; }
            }
        }
        
        // Main Content Area
        VerticalBox {
            padding: 0px;
            spacing: 0px;
            
            // Top Header Bar
            Rectangle {
                height: 70px;
                background: #0B0F19;
                
                // Replaced border-bottom-width with an explicit divider line
                Rectangle {
                    y: parent.height - 1px;
                    height: 1px;
                    width: parent.width;
                    background: #1F2937;
                }
                
                HorizontalBox {
                    padding-left: 20px;
                    padding-right: 20px;
                    alignment: space-between;
                    
                    Text { text: "Operations Console"; font-size: 18px; color: white; vertical-alignment: center; }
                    
                    HorizontalBox {
                        spacing: 15px;
                        VerticalBox {
                            alignment: center;
                            Text { text: root.current_user_name; color: white; font-weight: 700; horizontal-alignment: right; }
                            Text { text: root.current_user_role + " | Last: " + root.last_login; color: #38BDF8; font-size: 11px; horizontal-alignment: right; }
                        }
                        Rectangle { width: 40px; height: 40px; border-radius: 20px; background: #38BDF8; y: 15px; } // Avatar
                    }
                }
            }
            
            DashboardView {}
        }
    }
}