// =========================================================================
// IronVault Cyber-Vault Secure Login Canvas (login.slint)
// =========================================================================

import { Theme } from "theme.slint";
import { Button, LineEdit } from "std-widgets.slint";

export component LoginScreen inherits Rectangle {
background: Theme.colors.background;

in-out property <string> error-message: "";
in-out property <string> hardware-id: "";

callback attempt-login(string, string);
callback trigger-registration(string, string);

/* STREAMING_CHUNK: Aligning the login gateway card horizontally and vertically... */
// Master Vertical Layout handles vertical Y-axis centering cleanly
VerticalLayout {
    alignment: center;
    spacing: Theme.space-xl;

    // Row 1: Core Branding Header Group (Centered Horizontally)
    HorizontalLayout {
        alignment: center;
        
        VerticalLayout {
            spacing: Theme.space-xs;
            alignment: center;
            
            Text {
                text: "IRONVAULT // SECURE ACCESS";
                font-size: 26px;
                font-weight: 800;
                font-family: Theme.font-family;
                color: Theme.colors.primary;
                horizontal-alignment: center;
            }
            Text {
                text: "ENTERPRISE CRYPTOGRAPHIC CREDENTIAL GATEWAY";
                font-size: 11px;
                font-family: Theme.mono-font;
                color: Theme.colors.text-muted;
                horizontal-alignment: center;
            }
        }
    }

    // Row 2: Main Login Credentials Card Container (Centered Horizontally)
    HorizontalLayout {
        alignment: center;
        
        Rectangle {
            background: Theme.colors.surface;
            border-color: Theme.colors.border;
            border-width: 1px;
            border-radius: Theme.border-radius;
            width: 420px;

            // Internal Form Content Layout Stack
            VerticalLayout {
                padding: Theme.space-xl;
                spacing: Theme.space-lg;

                Text {
                    text: "AUTHENTICATION AUTHORITY REQUISITION";
                    font-size: 12px;
                    font-family: Theme.mono-font;
                    color: Theme.colors.text;
                    font-weight: 700;
                }

                // Operator Identity Field Group
                VerticalLayout {
                    spacing: Theme.space-sm;
                    
                    Text { 
                        text: "OPERATOR IDENTIFIER"; 
                        font-size: 10px; 
                        color: Theme.colors.text-muted; 
                        font-family: Theme.mono-font; 
                    }
                    
                    username-input := LineEdit {
                        placeholder-text: "Enter registered admin hash id...";
                        height: 42px;
                    }
                }

                // Cryptographic Verification Password Field Group
                VerticalLayout {
                    spacing: Theme.space-sm;
                    
                    Text { 
                        text: "SECRET VERIFICATION PASSWORD"; 
                        font-size: 10px; 
                        color: Theme.colors.text-muted; 
                        font-family: Theme.mono-font; 
                    }
                    
                    password-input := LineEdit {
                        placeholder-text: "••••••••••••••••";
                        input-type: password;
                        height: 42px;
                    }
                }

                // Dynamic System Status/Error Banner Display
                if error-message != "" : Rectangle {
                    background: Theme.colors.error.with-alpha(0.12);
                    border-color: Theme.colors.error;
                    border-width: 1px;
                    border-radius: 4px;
                    
                    HorizontalLayout {
                        padding: Theme.space-sm;
                        alignment: center;
                        Text {
                            text: error-message;
                            color: Theme.colors.error;
                            font-size: 11px;
                            font-family: Theme.font-family;
                            wrap: word-wrap;
                        }
                    }
                }

                // Interactive Action Buttons Row
                HorizontalLayout {
                    spacing: Theme.space-md;
                    
                    Button {
                        text: "INITIALIZE SIGN IN";
                        primary: true;
                        height: 42px;
                        clicked => {
                            root.attempt-login(username-input.text, password-input.text);
                        }
                    }

                    Button {
                        text: "REGISTER PROTOCOL";
                        height: 42px;
                        clicked => {
                            root.trigger-registration(username-input.text, password-input.text);
                        }
                    }
                }
            }
        }
    }

    // Row 3: Physical Machine Hardware Node Binding Footer (Centered Horizontally)
    HorizontalLayout {
        alignment: center;
        
        VerticalLayout {
            spacing: Theme.space-xs;
            alignment: center;
            
            Text {
                text: "SYSTEM HARDWARE BINDING SECURED";
                font-size: 10px;
                font-family: Theme.mono-font;
                color: Theme.colors.success;
                horizontal-alignment: center;
            }
            Text {
                text: root.hardware-id;
                font-size: 10px;
                font-family: Theme.mono-font;
                color: Theme.colors.text-muted;
                horizontal-alignment: center;
            }
        }
    }
}


}