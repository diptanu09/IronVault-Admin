// Master window with sidebar + content router
// Main entry point for the Slint UI

import { Button, LineEdit, ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { RegisterView, RegisterFormFields } from "views/register.slint";

// --- UPGRADED PREMIUM NAV ITEM ---
component NavItem inherits Rectangle {
    in property <string> text;
    in property <image> icon_source;
    in property <bool> active;
    in property <bool> collapsed;
    callback clicked();
    
    height: 42px;
    border-radius: 8px;
    
    // Smooth background hover and active state transitions
    background: ta.pressed ? #27272A : (ta.has-hover ? #1F2937 : (active ? #1E293B : transparent));
    border-width: active ? 1px : 0px;
    border-color: Theme.brand-primary;
    
    animate background { duration: 150ms; }

    HorizontalLayout {
        // Strict geometric padding to ensure perfect centering when collapsed
        padding-left: root.collapsed ? 0px : 14px;
        padding-right: root.collapsed ? 0px : 14px;
        alignment: root.collapsed ? LayoutAlignment.center : LayoutAlignment.start;
        spacing: 14px;
        
        VerticalLayout {
            alignment: center;
            Image {
                source: root.icon_source;
                width: 22px; height: 22px;
                image-fit: contain; // Prevents icon warping
                
                // Using opacity instead of colorize preserves complex PNG beauty
                opacity: root.active ? 1.0 : 0.5;
                animate opacity { duration: 200ms; }
            }
        }
        
        if (!root.collapsed) : VerticalLayout {
            alignment: center;
            Text { 
                text: root.text; 
                font-size: 14px; 
                font-weight: root.active ? 800 : 600; 
                color: root.active ? Theme.text-primary : Theme.text-secondary; 
                animate color { duration: 200ms; }
            }
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

export struct UserData {
    username: string,
    role: string,
    last_login: string,
    full_name: string,
    designation: string,
    expires_at: string,
}

export component AppWindow inherits Window {
    title: "IronVault Operator Administration Console";
    
    preferred-width: 1280px; 
    preferred-height: 760px;
    min-width: 1024px;
    min-height: 600px;
    
    background: Theme.bg-main; 
    icon: @image-url("assets/app_icon.png");

    in-out property <bool> sidebar_collapsed: false;

    in-out property <string> hwid_string: "HWID: UNKNOWN";
    in-out property <string> current_user_name: "GUEST";
    in-out property <string> current_user_role: "UNAUTHORIZED";
    in-out property <string> last_login: "NEVER";
    in-out property <bool> is_logged_in: false;
    
    in-out property <string> auth_screen_state: "landing"; 
    in-out property <string> active_tab: "overview";

    in-out property <string> captcha_q_main: "0 + 0";
    in-out property <string> captcha_a_main: "0";
    in-out property <string> login_error: "";

    in-out property <string> form_user: "";
    in-out property <string> form_pass: "";
    in-out property <string> form_captcha_login: "";
    
    in-out property <RegisterFormFields> registration_fields;

    in-out property <string> pending_notification_name: "NONE";
    in-out property <string> polling_error_msg: "";
    in-out property <[UserData]> active_users_list: [];

    callback request_authentication(string, string);
    callback request_registration(string, string, string, string, string, string, string);
    callback approve_pending_operator(string, string);
    callback deny_pending_operator(string);
    callback request_logout();
    callback load_users_list();
    callback update_user_role(string, string);
    callback extend_user_lease(string, string, string);
    callback ban_user(string);

    HorizontalLayout {
        padding: 0px; spacing: 0px;

        if (root.is_logged_in) : Rectangle {
            // 74px provides the exact mathematical space for a perfect 42x42 centered square button
            width: root.sidebar_collapsed ? 74px : 260px;
            background: Theme.bg-sidebar;
            border-width: 1px; border-color: Theme.border-dark;
            drop-shadow-blur: 15px; drop-shadow-color: #00000099;
            animate width { duration: 200ms; easing: ease-in-out; }

            VerticalLayout {
                padding: 16px; spacing: 10px; alignment: start;
                
                HorizontalLayout {
                    alignment: root.sidebar_collapsed ? LayoutAlignment.center : LayoutAlignment.space-between;
                    padding-bottom: 12px;
                    
                    if (!root.sidebar_collapsed) : VerticalLayout {
                        spacing: 2px; alignment: center;
                        Text { text: "❖ IRONVAULT"; font-size: 16px; font-weight: 900; color: Theme.brand-primary; letter-spacing: 1px; }
                        Text { text: "COMMAND CENTER"; font-size: 9px; font-weight: 700; color: Theme.text-muted; letter-spacing: 1px; }
                    }
                    
                    Rectangle {
                        width: 32px; height: 32px;
                        border-radius: 6px;
                        background: toggle_ta.has-hover ? #1F2937 : transparent;
                        animate background { duration: 150ms; }
                        
                        Text {
                            text: root.sidebar_collapsed ? "»" : "«";
                            font-size: 18px;
                            font-weight: 900;
                            color: Theme.brand-primary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        toggle_ta := TouchArea {
                            clicked => { root.sidebar_collapsed = !root.sidebar_collapsed; }
                        }
                    }
                }
                
                if (!root.sidebar_collapsed) : Text { text: root.hwid_string; font-size: 9px; color: Theme.text-dark; padding-bottom: 8px; }
                
                Rectangle { height: 1px; background: Theme.border-dark; }
                Rectangle { height: 8px; }

                NavItem {
                    text: "Dashboard"; icon_source: @image-url("assets/dashboard.png"); 
                    active: root.active_tab == "overview";
                    collapsed: root.sidebar_collapsed;
                    clicked => { root.active_tab = "overview"; }
                }
                
                if (root.current_user_role == "SuperAdmin" || root.current_user_role == "super_admin") : NavItem {
                    text: "Access Requests"; icon_source: @image-url("assets/requests.png"); 
                    active: root.active_tab == "approvals";
                    collapsed: root.sidebar_collapsed;
                    clicked => { root.active_tab = "approvals"; }
                }

                if (root.current_user_role == "SuperAdmin" || root.current_user_role == "super_admin") : NavItem {
                    text: "Operator Matrix"; icon_source: @image-url("assets/matrix.png"); 
                    active: root.active_tab == "users";
                    collapsed: root.sidebar_collapsed;
                    clicked => { root.active_tab = "users"; root.load_users_list(); }
                }

                Rectangle { vertical-stretch: 1; }
                
                Rectangle { height: 8px; }
                Rectangle { height: 1px; background: Theme.border-dark; }
                Rectangle { height: 8px; }

                NavItem {
                    text: "Terminate Session"; icon_source: @image-url("assets/logout.png"); 
                    active: false;
                    collapsed: root.sidebar_collapsed;
                    clicked => { root.request_logout(); }
                }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            background: @linear-gradient(135deg, #09090B 0%, #111827 100%); 
            
            if (!root.is_logged_in) : VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    
                    Rectangle {
                        width: root.auth_screen_state == "register" ? 680px : 440px; 
                        background: Theme.bg-card; border-radius: 12px; border-width: 1px; border-color: Theme.border-color;
                        drop-shadow-blur: 30px; drop-shadow-color: #000000B3;
                        animate width { duration: 250ms; easing: ease-in-out; }

                        VerticalLayout {
                            padding: 40px; spacing: 16px;

                            VerticalLayout {
                                alignment: center; spacing: 5px; padding-bottom: 5px;
                                Text { text: "❖ IRONVAULT"; font-size: 28px; font-weight: 900; color: Theme.brand-primary; horizontal-alignment: center; }
                                if (root.auth_screen_state == "landing") : Text { text: "CORE PLATFORM ROUTER"; font-size: 11px; font-weight: 700; color: Theme.text-muted; horizontal-alignment: center; letter-spacing: 2px; }
                                if (root.auth_screen_state == "login") : Text { text: "SECURE OPERATOR LOGIN"; font-size: 11px; font-weight: 700; color: Theme.text-secondary; horizontal-alignment: center; letter-spacing: 2px; }
                                if (root.auth_screen_state == "register") : Text { text: "NODE INITIALIZATION DEPLOYMENT"; font-size: 11px; font-weight: 700; color: Theme.text-secondary; horizontal-alignment: center; letter-spacing: 2px; }
                            }
                            
                            Rectangle { height: 1px; background: Theme.border-color; }

                            if (root.auth_screen_state == "landing") : VerticalLayout {
                                spacing: 16px; padding-top: 10px;
                                Button {
                                    text: "🔒 Access Terminal Login"; height: 45px;
                                    clicked => { root.auth_screen_state = "login"; root.login_error = ""; }
                                }
                                Button {
                                    text: "🛰️ Enroll New Node Profile"; height: 45px;
                                    clicked => { root.auth_screen_state = "register"; root.login_error = ""; }
                                }
                            }

                            if (root.auth_screen_state == "login") : VerticalLayout {
                                spacing: 14px;
                                
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "OPERATOR IDENTITY ACCOUNT"; font-size: 10px; color: Theme.text-secondary; font-weight: 800; }
                                    LineEdit { text <=> root.form_user; placeholder_text: "Enter identity sequence..."; height: 34px; }
                                }
                                
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "CRYPTOGRAPHIC ACCESS SIGNATURE"; font-size: 10px; color: Theme.text-secondary; font-weight: 800; }
                                    LineEdit { text <=> root.form_pass; placeholder_text: "Enter token secret..."; input-type: password; height: 34px; }
                                }
                                
                                VerticalLayout {
                                    spacing: 4px;
                                    Text { text: "SECURITY CHALLENGE MATRIX"; font-size: 10px; color: Theme.text-secondary; font-weight: 800; }
                                    HorizontalLayout {
                                        spacing: 12px;
                                        Rectangle {
                                            background: Theme.border-color; border-radius: 4px; horizontal-stretch: 1; height: 36px;
                                            Text { text: "Solve Sequence: " + root.captcha_q_main; font-size: 12px; font-weight: 700; color: Theme.text-primary; vertical-alignment: center; horizontal-alignment: center; }
                                        }
                                        LineEdit { text <=> root.form_captcha_login; width: 110px; height: 36px; placeholder_text: "Result"; }
                                    }
                                }

                                if (root.login_error != "") : Rectangle {
                                    background: #7F1D1D33; border-radius: 6px; border-width: 1px; border-color: Theme.brand-danger;
                                    HorizontalLayout { padding: 8px; Text { text: root.login_error; color: #FCA5A5; font-size: 12px; font-weight: 600; wrap: word-wrap; horizontal-alignment: center; } }
                                }

                                HorizontalLayout {
                                    spacing: 14px; padding-top: 18px; 
                                    Button {
                                        text: "Authenticate Access"; height: Theme.button-height; horizontal-stretch: 1;
                                        clicked => {
                                            if (root.form_captcha_login == root.captcha_a_main) { root.request_authentication(root.form_user, root.form_pass); }
                                            else { root.login_error = "Validation Fault: Challenge mismatch."; }
                                        }
                                    }
                                    Button {
                                        text: "Return to Gateway"; height: Theme.button-height; horizontal-stretch: 1;
                                        clicked => { root.auth_screen_state = "landing"; root.login_error = ""; }
                                    }
                                }
                            }

                            if (root.auth_screen_state == "register") : RegisterView {
                                captcha-question: root.captcha_q_main;
                                operational-error: root.login_error;
                                form-data <=> root.registration_fields;
                                
                                submit-registration => {
                                    if (root.registration_fields.captcha-result == root.captcha_a_main) {
                                        root.request_registration(
                                            root.registration_fields.username,
                                            root.registration_fields.secret,
                                            root.registration_fields.first-name,
                                            root.registration_fields.middle-name,
                                            root.registration_fields.last-name,
                                            root.registration_fields.designation,
                                            root.registration_fields.section
                                        );
                                    } else {
                                        root.login_error = "Validation Fault: Challenge mismatch.";
                                    }
                                }
                                cancel-registration => {
                                    root.auth_screen_state = "landing";
                                    root.login_error = "";
                                }
                            }
                        }
                    }
                }
            }

            if (root.is_logged_in) : VerticalLayout {
                padding: 40px; spacing: 25px;

                if (root.active_tab == "overview") : VerticalLayout {
                    spacing: 20px;
                    Text { text: "Security Command Dashboard"; font-size: 28px; font-weight: 800; color: Theme.text-primary; }
                    
                    Rectangle {
                        background: Theme.bg-card; border-radius: 12px; border-width: 1px; border-color: Theme.border-color;
                        drop-shadow-blur: 10px; drop-shadow-color: #00000040;
                        
                        VerticalLayout {
                            padding: 25px; spacing: 15px;
                            HorizontalLayout {
                                spacing: 15px;
                                Text { text: "⚙️"; font-size: 24px; vertical-alignment: center; }
                                Text { text: "Active Node Diagnostics"; font-size: 18px; font-weight: 700; color: Theme.brand-success; vertical-alignment: center; } 
                            }
                            Rectangle { height: 1px; background: Theme.border-color; }
                            Text { text: "Operator Identity:  " + root.current_user_name; color: #F3F4F6; font-size: 15px; font-weight: 600;}
                            Text { text: "Authority Class:    " + root.current_user_role; color: #F3F4F6; font-size: 15px; font-weight: 600;}
                            Text { text: "Database Binding:   " + root.last_login; color: Theme.text-secondary; font-size: 14px; }
                        }
                    }
                }

                if (root.active_tab == "approvals") : VerticalLayout {
                    spacing: 20px;
                    Text { text: "Pending Access Router"; font-size: 28px; font-weight: 800; color: Theme.text-primary; }
                    
                    Rectangle {
                        background: Theme.bg-card; border-radius: 12px; border-width: 1px; border-color: Theme.border-color;
                        
                        VerticalLayout {
                            padding: 30px; spacing: 20px;
                            if (root.pending_notification_name != "NONE") : VerticalLayout {
                                spacing: 15px;
                                Text { text: "⚠️ Incoming Authorization Request Intercepted"; font-size: 16px; color: Theme.brand-warning; font-weight: 800; } 
                                Text { text: "Target Account: " + root.pending_notification_name; font-size: 18px; font-weight: 700; color: Theme.text-primary; }
                                
                                HorizontalLayout {
                                    spacing: 15px;
                                    role_selector := LineEdit { text: "Operator"; placeholder_text: "Assign role"; width: 200px; height: 35px; }
                                    Button { text: "Grant Authorization"; clicked => { root.approve_pending_operator(root.pending_notification_name, role_selector.text); } }
                                    Button { text: "Purge Request"; clicked => { root.deny_pending_operator(root.pending_notification_name); } }
                                }
                            }
                            if (root.pending_notification_name == "NONE") : Text { 
                                text: "No pending terminal authorization links detected in current cycle buffer."; 
                                color: Theme.text-muted; font-size: 15px; font-italic: true; 
                            }
                        }
                    }
                }

                if (root.active_tab == "users") : VerticalLayout {
                    spacing: 20px; vertical-stretch: 1;
                    
                    VerticalLayout {
                        spacing: 8px;
                        Text { text: "Active Operator Control Matrix"; font-size: 28px; font-weight: 800; color: Theme.text-primary; }
                        Text { text: "Live administration node. Access leases auto-enforce system lockdowns outside validity parameters."; font-size: 14px; color: Theme.text-secondary; }
                    }

                    Rectangle {
                        background: Theme.bg-card; border-radius: 12px; border-width: 1px; border-color: Theme.border-color;
                        drop-shadow-blur: 10px; drop-shadow-color: #00000040;
                        vertical-stretch: 1;
                        
                        VerticalLayout {
                            padding: 24px; spacing: 0px;
                            
                            HorizontalLayout {
                                padding-bottom: 16px; spacing: 15px;
                                Text { text: "OPERATOR / NAME"; width: 180px; font-size: 12px; font-weight: 800; color: Theme.text-muted; letter-spacing: 1px; }
                                Text { text: "DESIGNATION"; width: 160px; font-size: 12px; font-weight: 800; color: Theme.text-muted; letter-spacing: 1px; }
                                Text { text: "LEASE EXPIRES"; width: 120px; font-size: 12px; font-weight: 800; color: Theme.text-muted; letter-spacing: 1px; }
                                Text { text: "ASSIGNMENT"; width: 120px; font-size: 12px; font-weight: 800; color: Theme.text-muted; letter-spacing: 1px; }
                                Text { text: "DAYS"; width: 60px; font-size: 12px; font-weight: 800; color: Theme.text-muted; letter-spacing: 1px; }
                                Text { text: "ROUTING ACTIONS"; horizontal-stretch: 1; font-size: 12px; font-weight: 800; color: Theme.text-muted; letter-spacing: 1px; }
                            }
                            
                            Rectangle { height: 1px; background: Theme.border-color; }
                            Rectangle { height: 16px; background: transparent; }

                            ScrollView {
                                width: 100%; vertical-stretch: 1;
                                
                                VerticalLayout {
                                    spacing: 14px; alignment: start; padding-bottom: 20px;
                                    
                                    for user in root.active_users_list : HorizontalLayout {
                                        spacing: 15px;
                                        
                                        VerticalLayout {
                                            width: 180px; spacing: 2px; alignment: center;
                                            Text { text: "👤 " + user.username; color: #F3F4F6; font-size: 14px; font-weight: 700; overflow: elide; }
                                            Text { text: user.full_name; color: Theme.text-muted; font-size: 11px; font-weight: 600; overflow: elide; }
                                        }

                                        Text { text: user.designation; width: 160px; color: Theme.text-secondary; font-size: 13px; vertical-alignment: center; wrap: word-wrap; }
                                        Text { text: user.expires_at; width: 120px; color: (user.expires_at == "LIFETIME" ? Theme.brand-success : Theme.brand-warning); font-size: 12px; vertical-alignment: center; overflow: elide; font-weight: 700; }
                                        
                                        role_input := LineEdit { text: user.role; width: 120px; height: 34px; }
                                        days_input := LineEdit { text: "30"; placeholder_text: "Days"; width: 60px; height: 34px; }
                                        
                                        Button {
                                            text: "Save"; width: 70px; height: 34px;
                                            clicked => { root.extend_user_lease(user.username, role_input.text, days_input.text); }
                                        }
                                        Button {
                                            text: "Ban"; width: 60px; height: 34px;
                                            clicked => { root.ban_user(user.username); }
                                        }
                                        
                                        Rectangle { horizontal-stretch: 1; }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}