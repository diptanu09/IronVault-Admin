                border_color: Theme.primary_dark;
                
                VerticalLayout {
                    alignment: center;
                    padding: Theme.spacing_lg;
                    spacing: Theme.spacing_md;
                    
                    Text {
                        text: "👥";
                        font_size: Theme.font_size_xlarge;
                    }
                    
                    Text {
                        text: "Active Users";
                        color: Theme.text_secondary;
                        font_size: Theme.font_size_base;
                    }
                    
                    Text {
                        text: "127";
                        color: Theme.success;
                        font_size: Theme.font_size_2xlarge;
                        font_weight: 700;
                    }
                }
            }
            
            // Security Status Card
            Rectangle {
                background: Theme.bg_secondary;
                border_radius: Theme.radius_lg;
                border_width: 1px;
                border_color: Theme.primary_dark;
                
                VerticalLayout {
                    alignment: center;
                    padding: Theme.spacing_lg;
                    spacing: Theme.spacing_md;
                    
                    Text {
                        text: "🛡️";
                        font_size: Theme.font_size_xlarge;
                    }
                    
                    Text {
