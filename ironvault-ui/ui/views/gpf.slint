import { Button, LineEdit, ScrollView } from "std-widgets.slint";
import { Theme } from "../theme.slint";

export struct GpfCaseDetails {
    regd_no: string,
    holder_name: string,
    series_id: string,
    account_no: string,
    balance: string,
    status: string
}

export component GpfFinalPaymentView inherits Rectangle {
    in-out property <string> active_schema_action;
    in-out property <string> op_status_msg;
    in-out property <bool> op_is_error;
    
    in-out property <string> op_regd_no;
    in-out property <string> op_series_id;
    in-out property <string> op_account_no;
    in-out property <string> op_gpf_new_status;
    in-out property <bool> gpf_case_found;
    in-out property <GpfCaseDetails> active_gpf_case;

    callback request_find_gpf_case(string);
    callback request_delete_full_case(string, string, string);
    callback request_delete_application(string);
    callback request_delete_precalc(string);
    callback request_update_gpf_status(string, string);
    callback request_delete_auth_reports(string);

    background: transparent;

    VerticalLayout {
        spacing: 24px;
        padding: 4px;

        // Sub-Navigation Glass Ribbon
        HorizontalLayout {
            spacing: 12px;
            alignment: start;
            Button { text: "🔍 Find Case Profile"; height: 34px; clicked => { root.active_schema_action = "gpffp_find"; } }
            Button { text: "🚨 Destructive Override Matrix"; height: 34px; clicked => { root.active_schema_action = "gpffp_clear"; } }
        }

        if (root.active_schema_action == "gpffp_find") : VerticalLayout {
            spacing: 20px;
            Rectangle {
                background: Theme.bg-card; border-radius: 16px; border-width: 1px; border-color: Theme.border-color;
                VerticalLayout {
                    padding: 24px; spacing: 16px;
                    Text { text: "CASE PROFILE ACQUISITION"; font-size: 13px; font-weight: 900; color: Theme.brand-primary; letter-spacing: 0.5px; }
                    HorizontalLayout {
                        spacing: 16px; alignment: start;
                        VerticalLayout { spacing: 6px; width: 300px; Text { text: "REGISTRATION NUMBER *"; font-size: 11px; font-weight: 800; color: Theme.text-muted; } LineEdit { text <=> root.op_regd_no; placeholder_text: "e.g. 45102/FP"; height: 36px; } }
                        VerticalLayout { alignment: end; Button { text: "Query System Enclave"; height: 36px; clicked => { root.request_find_gpf_case(root.op_regd_no); } } }
                    }
                }
            }

            if (root.gpf_case_found) : Rectangle {
                background: #11182766; border-radius: 16px; border-width: 1.5px; border-color: Theme.brand-success;
                VerticalLayout {
                    padding: 24px; spacing: 18px;
                    HorizontalLayout {
                        alignment: space-between;
                        Text { text: "Verified Relational Ledger Record matches"; font-size: 15px; font-weight: 800; color: Theme.text-primary; }
                        Rectangle { width: 10px; height: 10px; border-radius: 5px; background: Theme.brand-success; }
                    }
                    Rectangle { height: 1px; background: Theme.border-color; opacity: 0.3; }
                    HorizontalLayout {
                        spacing: 32px;
                        VerticalLayout { spacing: 4px; Text { text: "HOLDER ACCOUNT NAME"; font-size: 11px; color: Theme.text-muted; } Text { text: root.active_gpf_case.holder_name; font-size: 15px; font-weight: 700; color: Theme.text-primary; } }
                        VerticalLayout { spacing: 4px; Text { text: "SERIES PREFIX"; font-size: 11px; color: Theme.text-muted; } Text { text: root.active_gpf_case.series_id; font-size: 15px; font-family: "Consolas"; color: Theme.brand-warning; } }
                        VerticalLayout { spacing: 4px; Text { text: "LEDGER ACCOUNT NO"; font-size: 11px; color: Theme.text-muted; } Text { text: root.active_gpf_case.account_no; font-size: 15px; font-family: "Consolas"; } }
                        VerticalLayout { spacing: 4px; Text { text: "CLOSING BALANCE"; font-size: 11px; color: Theme.text-muted; } Text { text: "₹ " + root.active_gpf_case.balance; font-size: 16px; font-weight: 900; color: Theme.brand-primary; } }
                    }
                }
            }
        }

        if (root.active_schema_action == "gpffp_clear") : VerticalLayout {
            spacing: 20px;
            Rectangle {
                background: Theme.bg-card; border-radius: 16px; border-width: 1px; border-color: #EF44444D;
                VerticalLayout {
                    padding: 24px; spacing: 16px;
                    Text { text: "CRITICAL REGULATORY DATA PURGE LAYER"; font-size: 13px; font-weight: 900; color: Theme.brand-danger; letter-spacing: 0.5px; }
                    Text { text: "Warning: Destructive overrides commit immediate non-reversible cascading deletes inside Oracle clusters."; font-size: 12px; color: Theme.text-secondary; }
                    // FIXED: Removed invalid 'wrap' property to resolve compiler rejection diagnostic
                    HorizontalLayout {
                        spacing: 16px;
                        Button { text: "💥 Drop Full Settlement Case"; clicked => { root.request_delete_full_case(root.op_regd_no, root.op_series_id, root.op_account_no); } }
                        Button { text: "🗑️ Purge Application Row"; clicked => { root.request_delete_application(root.op_regd_no); } }
                        Button { text: "📊 Clear Pre-Calculations"; clicked => { root.request_delete_precalc(root.op_regd_no); } }
                        Button { text: "📜 Drop Authority Reports"; clicked => { root.request_delete_auth_reports(root.op_regd_no); } }
                    }
                }
            }
        }
    }
}