import { Button, LineEdit, ScrollView } from "std-widgets.slint";
import { Theme, SchemaAction } from "../theme.slint";

export struct PensionDetailsSlint {
    application_no: string,
    pensioner_name: string,
    employee_code: string,
    designation: string,
    mobile_no: string,
    date_of_birth: string,
}

export struct PensionStatusSlint {
    application_no: string,
    application_date: string,
    name: string,
    last_work_office_name: string,
    status: string,
    date_of_settle: string,
    ppo: string,
    gpo: string,
    cpo: string,
    dak_outward_date: string,
    speed_post: string,
    treasury: string,
}

export component PensionView inherits VerticalLayout {
    in-out property <string> active_schema_action;
    in-out property <string> op_status_msg;
    in-out property <bool> op_is_error;
    in-out property <string> search_query;
    in-out property <bool> data_found: false;
    
    in-out property <[PensionDetailsSlint]> biographical_list: [];
    in-out property <PensionStatusSlint> status_record;

    callback request_pension_details(string);
    callback request_pension_status(string);

    spacing: 20px;
    HorizontalLayout {
        spacing: 12px;
        SchemaAction { icon_text: "👤"; title: "Pensioner Profiles"; active: root.active_schema_action == "sai_biographical"; clicked => { root.active_schema_action = "sai_biographical"; root.op_status_msg = ""; root.data_found = false; } }
        SchemaAction { icon_text: "📈"; title: "Lifecycle Settlement Tracker"; active: root.active_schema_action == "sai_lifecycle"; clicked => { root.active_schema_action = "sai_lifecycle"; root.op_status_msg = ""; root.data_found = false; } }
    }
    Rectangle { height: 1px; background: Theme.border-color; opacity: 0.3; }

    if (root.active_schema_action == "sai_biographical") : Rectangle {
        background: Theme.bg-card; border-radius: 16px; border-width: 1px; border-color: Theme.border-color;
        VerticalLayout {
            padding: 30px; spacing: 20px;
            Text { text: "SAI_AGARTALA PENSIONERS PROFILE QUERY ENGINE"; font-size: 16px; font-weight: 900; color: Theme.brand-primary; }
            HorizontalLayout { spacing: 15px; VerticalLayout { spacing: 4px; horizontal-stretch: 1; Text { text: "SEARCH TERM (APPLICATION NO / EMP CODE / NAME)"; font-size: 11px; font-weight: 800; color: Theme.text-secondary; } LineEdit { text <=> root.search_query; placeholder_text: "Type criteria identity details..."; height: 38px; } } }
            Button { text: "🔍  Scan Biographical Ledger Context"; height: 42px; clicked => { root.request_pension_details(root.search_query); } }
            
            if (root.data_found) : ScrollView {
                height: 250px;
                VerticalLayout {
                    spacing: 10px;
                    for pnsr in root.biographical_list : Rectangle {
                        background: #FFFFFF03; border-radius: 8px; border-width: 1px; border-color: #FFFFFF0A;
                        VerticalLayout {
                            padding: 14px; spacing: 8px;
                            HorizontalLayout {
                                alignment: space-between;
                                Text { text: pnsr.pensioner_name; font-size: 14px; font-weight: 800; color: Theme.brand-primary; }
                                Text { text: "App No: " + pnsr.application_no; font-size: 12px; color: Theme.text-muted; }
                            }
                            HorizontalLayout {
                                spacing: 20px;
                                Text { text: "Designation: " + pnsr.designation; font-size: 12px; color: Theme.text-secondary; }
                                Text { text: "Code: " + pnsr.employee_code; font-size: 12px; color: Theme.text-secondary; }
                                Text { text: "Mobile: " + pnsr.mobile_no; font-size: 12px; color: Theme.brand-success; }
                            }
                        }
                    }
                }
            }
        }
    }

    if (root.active_schema_action == "sai_lifecycle") : Rectangle {
        background: Theme.bg-card; border-radius: 16px; border-width: 1px; border-color: Theme.border-color;
        VerticalLayout {
            padding: 30px; spacing: 20px;
            Text { text: "PENSION LIFECYCLE SETTLEMENT MATRIX STATUS TRACKER"; font-size: 16px; font-weight: 900; color: Theme.brand-primary; }
            HorizontalLayout { spacing: 15px; VerticalLayout { spacing: 4px; horizontal-stretch: 1; Text { text: "TARGET APPLICATION TRACKING NUMBER"; font-size: 11px; font-weight: 800; color: Theme.text-secondary; } LineEdit { text <=> root.search_query; placeholder_text: "Enter exact APPLN_NO..."; height: 38px; } } }
            Button { text: "📈  Extract Real-Time Dispatch Pipeline Logs"; height: 42px; clicked => { root.request_pension_status(root.search_query); } }
            
            if (root.data_found) : VerticalLayout {
                spacing: 16px;
                Rectangle { height: 1px; background: Theme.border-color; opacity: 0.3; }
                HorizontalLayout {
                    spacing: 20px;
                    VerticalLayout { spacing: 4px; horizontal-stretch: 2; Text { text: "BENEFICIARY NAME"; font-size: 9px; color: Theme.text-muted; } Text { text: root.status_record.name; font-size: 15px; font-weight: 900; color: Theme.text-primary; } }
                    VerticalLayout { spacing: 4px; horizontal-stretch: 1; Text { text: "APPLICATION DATE"; font-size: 9px; color: Theme.text-muted; } Text { text: root.status_record.application_date; font-size: 14px; font-weight: 700; color: Theme.text-secondary; } }
                    VerticalLayout { spacing: 4px; horizontal-stretch: 1; Text { text: "CURRENT STATUS"; font-size: 9px; color: Theme.text-muted; } Text { text: root.status_record.status; font-size: 14px; font-weight: 800; color: Theme.brand-warning; } }
                }
                
                // FIXED: Wrapped inside HorizontalLayout container to safely apply layout padding properties
                Rectangle {
                    background: #FFFFFF02; border-radius: 8px;
                    HorizontalLayout {
                        padding: 12px; spacing: 20px;
                        VerticalLayout { spacing: 2px; horizontal-stretch: 1; Text { text: "PPO AUTHORITY"; font-size: 9px; color: Theme.text-muted; } Text { text: root.status_record.ppo; font-size: 13px; font-weight: 700; color: Theme.brand-primary; } }
                        VerticalLayout { spacing: 2px; horizontal-stretch: 1; Text { text: "GPO AUTHORITY"; font-size: 9px; color: Theme.text-muted; } Text { text: root.status_record.gpo; font-size: 13px; font-weight: 700; color: Theme.brand-primary; } }
                        VerticalLayout { spacing: 2px; horizontal-stretch: 1; Text { text: "CPO AUTHORITY"; font-size: 9px; color: Theme.text-muted; } Text { text: root.status_record.cpo; font-size: 13px; font-weight: 700; color: Theme.brand-primary; } }
                    }
                }
                
                // FIXED: Wrapped inside HorizontalLayout container to safely apply layout padding properties
                Rectangle {
                    background: #00E5FF05; border-radius: 8px; border-width: 1px; border-color: #00E5FF22;
                    HorizontalLayout {
                        padding: 12px; spacing: 20px;
                        VerticalLayout { spacing: 2px; horizontal-stretch: 1; Text { text: "LAST FORWARDED WORKING OFFICE"; font-size: 9px; color: Theme.text-muted; } Text { text: root.status_record.last_work_office_name; font-size: 13px; color: Theme.text-secondary; } }
                        VerticalLayout { spacing: 2px; width: 150px; Text { text: "DAK OUTWARD DATE"; font-size: 9px; color: Theme.text-muted; } Text { text: root.status_record.dak_outward_date; font-size: 13px; font-weight: 700; color: Theme.brand-success; } }
                        VerticalLayout { spacing: 2px; horizontal-stretch: 1; Text { text: "SPEED POST / BARCODE DISPATCH LOG"; font-size: 9px; color: Theme.text-muted; } Text { text: root.status_record.speed_post; font-size: 13px; font-weight: 900; color: Theme.brand-warning; } }
                    }
                }
            }
        }
    }
}