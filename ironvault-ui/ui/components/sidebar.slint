// Sidebar component - Navigation and app info

import { Theme } from "../theme.slint"; // FIXED: Corrected relative path

export component Sidebar {
    in property <string> app_version;
    in property <string> copyright_text;
    in property <string> current_view;
    
    callback navigate_view(string);
    callback logout();
    
    width: 240px;
    background: Theme.bg_surface;
    border_right_width: 2px;
    border_right_color: Theme.primary;
    
    VerticalLayout {
        spacing: 0;
        padding: Theme.spacing_lg;
        
        Rectangle {
            height: 60px;
            margin_bottom: Theme.spacing_lg;
            VerticalLayout {
                alignment: center;
                Text {
                    text: "IRONVAULT";
                    color: Theme.primary;
                    font_size: Theme.font_size_xlarge;
                    font_weight: 900;
                    letter_spacing: 2px;
                }
            }
        }
        
        VerticalLayout {
            spacing: Theme.spacing_sm;
            padding_top: Theme.spacing_lg;
            border_top_width: 1px;
            border_top_color: Theme.primary_dark;
            
            Text {
                text: "v\{root.app_version}"; // FIXED: Slint correct string formatting
                color: Theme.text_tertiary;
                font_size: Theme.font_size_small;
                horizontal_alignment: center;
            }
            
            Text {
                text: root.copyright_text;
                color: Theme.text_tertiary;
                font_size: Theme.font_size_small;
                horizontal_alignment: center;
                wrap: word_wrap;
            }
            
            Rectangle {
                height: 40px;
                background: Theme.error;
                border_radius: Theme.radius_md;
                
                HorizontalLayout {
                    alignment: center;
                    Text { text: "  Logout"; color: #FFFFFF; font_weight: 600; vertical_alignment: center; }
                }
                TouchArea { clicked => { root.logout(); } }
            }
        }
    }
}