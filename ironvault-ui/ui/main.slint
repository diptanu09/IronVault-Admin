// Master window with sidebar + content router
// Main entry point for the Slint UI

import { Button, LineEdit, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { LoginView } from "views/login.slint";

export component AppWindow inherits Window {
    title: "IRONVAULT // ADMINISTRATIVE CONTROL TERMINAL";
    width: 1024px;
    height: 720px;
    
    in-out property <bool> is_logged_in: false;
    in-out property <string> login_error: "";
    in-out property <string> hwid_string: "HWID: FETCHING...";
    
    in-out property <string> current_user_name: "GUEST";
    in-out property <string> current_user_role: "UNAUTHORIZED";
    in-out property <string> last_login: "NEVER";

    in-out property <string> pending_notification_name: "NONE";
    in-out property <string> polling_error_msg: ""; 
    
    in-out property <string> captcha_q_main: "";
    in-out property <string> captcha_a_main: "";
    
    in-out property <string> active_tab: "overview";

    callback request_authentication(string, string);
    callback request_registration(string, string);
    callback approve_pending_operator(string, string);
    callback deny_pending_operator(string); 

    background: #0B0F19;

    HorizontalBox {
        spacing: 0; padding: 0;

        if root.is_logged_in : Rectangle {
            width: 240px; background: #111827; border-width: 1px; border-color: #1F2937;

            VerticalBox {
                padding: 20px; spacing: 20px; alignment: start;

                VerticalBox {
                    spacing: 4px;
                    Text { text: "IRONVAULT CORE"; font-size: 18px; font-weight: 800; color: #38BDF8; }
                    Text { text: "Admin Infrastructure v0.1.0"; font-size: 10px; color: #6B7280; }
                }

                Rectangle { height: 2px; background: #1F2937; }

                VerticalBox {
                    spacing: 5px;
                    Text { text: "OPERATOR PROFILE:"; font-size: 10px; color: #9CA3AF; font-weight: 700; }
                    Text { text: root.current_user_name; font-size: 14px; font-weight: 600; color: #F3F4F6; }
                    Text { text: "Role: " + root.current_user_role; font-size: 11px; color: #10B981; }
                }

                Rectangle { height: 2px; background: #1F2937; }

                Button { text: "📊 System Overview"; clicked => { root.active_tab = "overview"; } }
                
                if (root.current_user_role == "SuperAdmin" || root.current_user_role == "super_admin" || root.current_user_role == "Superadmin" || root.current_user_role == "superadmin") : Button { 
                    text: "🔔 Approval Queue"; 
                    clicked => { root.active_tab = "approvals"; } 
                }

                Rectangle { vertical-stretch: 1; } 

                VerticalBox {
                    spacing: 4px;
                    Text { text: "SECURITY SIGNATURE:"; font-size: 9px; color: #4B5563; font-weight: 700; }
                    Text { text: root.hwid_string; font-size: 9px; color: #6B7280; wrap: word-wrap; }
                }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            
            if !root.is_logged_in : LoginView {
                error_message: root.login_error;
                captcha_question: root.captcha_q_main;
                captcha_answer: root.captcha_a_main;
                login_requested(user, pass) => { root.request_authentication(user, pass); }
                registration_requested(user, pass) => { root.request_registration(user, pass); }
            }

            if root.is_logged_in : VerticalBox {
                padding: 40px; spacing: 25px;

                if root.active_tab == "overview" : VerticalBox {
                    spacing: 20px;
                    VerticalBox {
                        spacing: 5px;
                        Text { text: "SYSTEM OPERATIONAL OVERVIEW"; font-size: 22px; font-weight: 800; color: #FFFFFF; }
                        Text { text: "Live node diagnostics connected to database cluster AsstPro"; font-size: 13px; color: #9CA3AF; }
                    }

                    HorizontalBox {
                        spacing: 20px;
                        Rectangle {
                            height: 100px; background: #111827; border-radius: 8px; border-width: 1px; border-color: #1F2937;
                            VerticalBox {
                                padding: 15px; alignment: center;
                                Text { text: "DB MATRIX CONNECTION"; font-size: 11px; color: #9CA3AF; font-weight: 700; }
                                Text { text: "ONLINE // SECURE"; font-size: 18px; color: #10B981; font-weight: 800; }
                            }
                        }
                        Rectangle {
                            height: 100px; background: #111827; border-radius: 8px; border-width: 1px; border-color: #1F2937;
                            VerticalBox {
                                padding: 15px; alignment: center;
                                Text { text: "INCOMING PENDING REQUESTS"; font-size: 11px; color: #9CA3AF; font-weight: 700; }
                                Text { text: root.pending_notification_name == "NONE" ? "0 CHANNELS" : "⚠️ ACTIONS REQUIRED"; font-size: 16px; color: root.pending_notification_name == "NONE" ? #6B7280 : #F59E0B; font-weight: 800; }
                            }
                        }
                    }

                    Rectangle {
                        background: #1E293B; border-radius: 8px;
                        VerticalBox {
                            padding-left: 20px; padding-right: 20px; padding-top: 20px; padding-bottom: 20px; spacing: 10px;
                            Text { text: "Welcome Back, Authorized Operator."; font-size: 16px; font-weight: 700; color: #38BDF8; }
                            Text { text: "The core database abstraction layer has loaded successfully. All access queries and actions performed within this panel will be appended directly to the physical system audit sequence trail table schema logs."; font-size: 13px; color: #E2E8F0; wrap: word-wrap; }
                        }
                    }
                }

                if (root.active_tab == "approvals" && (root.current_user_role == "SuperAdmin" || root.current_user_role == "super_admin" || root.current_user_role == "Superadmin" || root.current_user_role == "superadmin")) : VerticalBox {
                    spacing: 20px; alignment: start;

                    VerticalBox {
                        spacing: 5px;
                        Text { text: "PENDING SECURITY ENFORCEMENT QUEUE"; font-size: 22px; font-weight: 800; color: #FFFFFF; }
                        Text { text: "Review raw device profile entry registration logs and assign roles dynamically"; font-size: 13px; color: #9CA3AF; }
                    }

                    Rectangle {
                        width: 550px; background: #111827; border-radius: 10px; border-width: 1px; border-color: #1F2937;
                        
                        VerticalBox {
                            padding: 30px; spacing: 18px;

                            // FIXED: Moved padding to structural parent block correctly to eliminate Slint warnings
                            if root.polling_error_msg != "" : Rectangle {
                                background: #3B0712; border-radius: 6px; height: 50px; border-color: #991B1B; border-width: 1px;
                                HorizontalBox {
                                    padding-left: 15px;
                                    Text { text: "🚨 DATABASE ACCESS EXCEPTION:\n" + root.polling_error_msg; color: #FCA5A5; font-size: 11px; font-weight: 700; vertical-alignment: center; }
                                }
                            }

                            if root.pending_notification_name == "NONE" : Text {
                                text: "🎉 Excellent. All incoming registration requests have been authorized. Operational logs clean.";
                                color: #10B981; font-size: 14px; wrap: word-wrap;
                            }

                            if root.pending_notification_name != "NONE" : VerticalBox {
                                spacing: 15px;
                                Rectangle {
                                    background: #2D1510; border-radius: 6px; height: 45px;
                                    VerticalBox {
                                        alignment: center; padding-left: 15px;
                                        Text { text: "⚠️ PENDING INTERCEPT FROM OPERATOR: " + root.pending_notification_name; color: #F59E0B; font-weight: 700; }
                                    }
                                }
                                
                                VerticalBox {
                                    spacing: 5px;
                                    Text { text: "Assign Workspace Privilege Authority Level"; color: #9CA3AF; font-size: 12px; }
                                    assign_role := LineEdit { text: "Operator"; placeholder-text: "SuperAdmin, Admin, Operator"; }
                                }

                                HorizontalBox {
                                    spacing: 12px;
                                    Button {
                                        text: "APPROVE PROFILE & ASSIGN ROLE";
                                        clicked => { root.approve_pending_operator(root.pending_notification_name, assign_role.text); }
                                    }
                                    Button {
                                        text: "❌ REJECT & DENY";
                                        clicked => { root.deny_pending_operator(root.pending_notification_name); }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}