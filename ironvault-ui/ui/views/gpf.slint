import { Button, LineEdit } from "std-widgets.slint";
import { Theme, SchemaAction } from "../theme.slint";

export struct GpfCaseDetails {
    regd_no: string,
    holder_name: string,
    series_id: string,
    account_no: string,
    balance: string,
    status: string,
}

export component GpfFinalPaymentView inherits VerticalLayout {
    in-out property <string> active_schema_action;
    in-out property <string> op_status_msg;
    in-out property <bool> op_is_error;
    in-out property <string> op_regd_no;
    in-out property <string> op_series_id;
    in-out property <string> op_account_no;
    in-out property <string> op_gpf_new_status;
    in-out property <bool> gpf_case_found;
    in-out property <GpfCaseDetails> active_gpf_case;

    callback request_find_gpf_case(string);
    callback request_delete_full_case(string, string, string);
    callback request_delete_application(string);
    callback request_delete_precalc(string);
    callback request_update_gpf_status(string, string);

    spacing: 20px;
    HorizontalLayout {
        spacing: 12px;
        SchemaAction { 
            icon_text: "🔍"; 
            title: "Get Case Details"; 
            active: root.active_schema_action == "gpffp_find"; 
            clicked => { root.active_schema_action = "gpffp_find"; root.op_status_msg = ""; } }
        SchemaAction { 
            icon_text: "✏️"; 
            title: "Update Case Status"; 
            active: root.active_schema_action == "gpffp_update"; 
            clicked => { root.active_schema_action = "gpffp_update"; root.op_status_msg = ""; } }
        SchemaAction { 
            icon_text: "🗑️"; 
            title: "Destructive Options"; 
            active: root.active_schema_action == "gpffp_delete"; 
            clicked => { root.active_schema_action = "gpffp_delete"; root.op_status_msg = ""; } }
    }
    Rectangle { height: 1px; background: Theme.border-color; opacity: 0.3; }
    
    if (root.active_schema_action == "gpffp_find") : Rectangle {
        background: Theme.bg-card; border-radius: 16px; border-width: 1px; border-color: Theme.brand-primary; drop-shadow-blur: 15px; drop-shadow-color: #00E5FF1A;
        VerticalLayout {
            padding: 30px; spacing: 20px;
            Text { text: "GPF CASE DISCOVERY ENGINE"; font-size: 16px; font-weight: 900; color: Theme.brand-primary; letter-spacing: 1px; }
            HorizontalLayout { spacing: 15px; VerticalLayout { spacing: 4px; horizontal-stretch: 1; Text { text: "REGISTRATION NUMBER (REGD_NO)"; font-size: 11px; font-weight: 800; color: Theme.text-secondary; } LineEdit { text <=> root.op_regd_no; placeholder_text: "Enter REGD_NO identity..."; height: 38px; } } }
            HorizontalLayout { 
                spacing: 15px; 
                Button { 
                    text: "🔍  Discover Case Profile Natively";
                    height: 42px;
                    horizontal-stretch: 1; 
                    clicked => { root.request_find_gpf_case(root.op_regd_no); } } }
            if (root.gpf_case_found) : VerticalLayout {
                spacing: 0px; Rectangle { height: 10px; }
                Rectangle {
                    background: #00E5FF05; border-radius: 12px; border-width: 1px; border-color: #00E5FF33;
                    VerticalLayout {
                        padding: 20px; spacing: 14px;
                        Text { text: "DISCOVERED FILE PROFILE META ATTRIBUTES"; font-size: 13px; font-weight: 900; color: Theme.brand-warning; letter-spacing: 0.5px; }
                        HorizontalLayout {
                            spacing: 20px;
                            VerticalLayout { spacing: 4px; horizontal-stretch: 1; Text { text: "REGISTRATION NUMBER"; font-size: 10px; font-weight: 800; color: Theme.text-muted; } Text { text: root.active_gpf_case.regd_no; font-size: 14px; font-weight: 800; color: Theme.text-primary; } }
                            VerticalLayout { spacing: 4px; horizontal-stretch: 1; Text { text: "ACCOUNT HOLDER NAME"; font-size: 10px; font-weight: 800; color: Theme.text-muted; } Text { text: root.active_gpf_case.holder_name; font-size: 14px; font-weight: 800; color: Theme.text-primary; } }
                            VerticalLayout { spacing: 4px; width: 100px; Text { text: "SERIES ID"; font-size: 10px; font-weight: 800; color: Theme.text-muted; } Text { text: root.active_gpf_case.series_id; font-size: 14px; font-weight: 800; color: Theme.brand-primary; } }
                            VerticalLayout { spacing: 4px; horizontal-stretch: 1; Text { text: "ACCOUNT NUMBER"; font-size: 10px; font-weight: 800; color: Theme.text-muted; } Text { text: root.active_gpf_case.account_no; font-size: 14px; font-weight: 800; color: Theme.brand-primary; } }
                        }
                        HorizontalLayout {
                            spacing: 20px;
                            VerticalLayout { spacing: 4px; horizontal-stretch: 1; Text { text: "CLOSING LEDGER BALANCE"; font-size: 10px; font-weight: 800; color: Theme.text-muted; } Text { text: "₹ " + root.active_gpf_case.balance; font-size: 16px; font-weight: 900; color: Theme.brand-success; } }
                            VerticalLayout { spacing: 4px; horizontal-stretch: 1; Text { text: "APPLICATION LIFECYCLE STATUS"; font-size: 10px; font-weight: 800; color: Theme.text-muted; } Text { text: root.active_gpf_case.status; font-size: 14px; font-weight: 800; color: Theme.brand-warning; } }
                        }
                    }
                }
            }
        }
    }
    if (root.active_schema_action == "gpffp_update") : Rectangle {
        background: Theme.bg-card; border-radius: 16px; border-width: 1px; border-color: Theme.brand-warning; drop-shadow-blur: 15px; drop-shadow-color: #F59E0B1A;
        VerticalLayout {
            padding: 30px; spacing: 20px;
            Text { text: "UPDATE GPF CASE STATUS OVERRIDE"; font-size: 16px; font-weight: 900; color: Theme.brand-warning; letter-spacing: 1px; }
            HorizontalLayout { 
                spacing: 15px;
                VerticalLayout { spacing: 4px; horizontal-stretch: 1; Text { text: "TARGET REGD_NO"; font-size: 11px; font-weight: 800; color: Theme.text-secondary; } LineEdit { text <=> root.op_regd_no; placeholder_text: "Target Application No"; height: 38px; } } 
                VerticalLayout { spacing: 4px; horizontal-stretch: 1; Text { text: "NEW STATUS CODE"; font-size: 11px; font-weight: 800; color: Theme.text-secondary; } LineEdit { text <=> root.op_gpf_new_status; placeholder_text: "Enter forced status..."; height: 38px; } } 
            }
            Button { text: "✏️ Commit Status Override"; height: 42px; clicked => { root.request_update_gpf_status(root.op_regd_no, root.op_gpf_new_status); } }
        }
    }
    if (root.active_schema_action == "gpffp_delete") : Rectangle {
        background: Theme.bg-card; border-radius: 16px; border-width: 1px; border-color: Theme.brand-danger; drop-shadow-blur: 15px; drop-shadow-color: #EF44441A;
        VerticalLayout {
            padding: 30px; spacing: 20px;
            Text { text: "GPFFP DESTRUCTIVE PROTOCOLS"; font-size: 16px; font-weight: 900; color: Theme.brand-danger; letter-spacing: 1px; }
            HorizontalLayout { spacing: 15px; VerticalLayout { spacing: 4px; horizontal-stretch: 1; Text { text: "TARGET REGD_NO"; font-size: 11px; font-weight: 800; color: Theme.text-secondary; } LineEdit { text <=> root.op_regd_no; placeholder_text: "Application No"; height: 38px; } } VerticalLayout { spacing: 4px; horizontal-stretch: 1; Text { text: "SERIES ID"; font-size: 11px; font-weight: 800; color: Theme.text-secondary; } LineEdit { text <=> root.op_series_id; placeholder_text: "Series"; height: 38px; } } VerticalLayout { spacing: 4px; horizontal-stretch: 1; Text { text: "ACCOUNT NO"; font-size: 11px; font-weight: 800; color: Theme.text-secondary; } LineEdit { text <=> root.op_account_no; placeholder_text: "Account"; height: 38px; } } }
            HorizontalLayout { spacing: 15px; Button { text: "Delete Full Case"; height: 42px; horizontal-stretch: 1; clicked => { root.request_delete_full_case(root.op_regd_no, root.op_series_id, root.op_account_no); } } Button { text: "Delete Application"; height: 42px; horizontal-stretch: 1; clicked => { root.request_delete_application(root.op_regd_no); } } Button { text: "Delete Pre-Calculation"; height: 42px; horizontal-stretch: 1; clicked => { root.request_delete_precalc(root.op_regd_no); } } }
        }
    }
}