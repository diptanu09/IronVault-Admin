                                        letter_subject <=> root.letter_subject;
                                        letter_no_of_copies <=> root.letter_no_of_copies;
                                        dak_ppo <=> root.dak_ppo;
                                        dak_fppo <=> root.dak_fppo;
                                        dak_gpo <=> root.dak_gpo;
                                        dak_cpo <=> root.dak_cpo;
                                        dak_adr_1 <=> root.dak_adr_1;
                                        dak_bar_1 <=> root.dak_bar_1;
                                        dak_sent_1 <=> root.dak_sent_1;
                                        dak_adr_2 <=> root.dak_adr_2;
                                        dak_bar_2 <=> root.dak_bar_2;
                                        dak_sent_2 <=> root.dak_sent_2;
                                        dak_adr_3 <=> root.dak_adr_3;
                                        dak_bar_3 <=> root.dak_bar_3;
                                        dak_sent_3 <=> root.dak_sent_3;
                                        dak_case_found <=> root.dak_case_found;
                                        view_dak_letter <=> root.view_dak_letter;
                                        view_dak_subject <=> root.view_dak_subject;
                                        view_dak_section <=> root.view_dak_section;
                                        dak_corr_date <=> root.dak_corr_date;
                                        request_find_pension_dak_meta(s) => { root.request_find_pension_dak_meta(s); }
                                        request_submit_outward_dak() => { root.request_submit_outward_dak(); }
