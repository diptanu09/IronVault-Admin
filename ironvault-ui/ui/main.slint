import { Button, LineEdit, VerticalBox, HorizontalBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "IRONVAULT // MULTI-DATABASE CONTROL CONSOLE";
    callback execute_11g_action(string, string);
    callback execute_12c_action(string, string);
    
    in-out property <string> status_text: "SYSTEM INITIALIZED // AWAITING COMMANDS";
    in-out property <string> status_color: "#56b4f8"; 

    width: 900px;
    height: 650px;
    background: #0f172a; // Deep slate charcoal canvas

    VerticalBox {
        padding: 20px;
        spacing: 15px;

        // Header Title Bar
        HorizontalBox {
            Text {
                text: "IRONVAULT CENTRAL MANAGEMENT HUB";
                font-size: 24px;
                font-weight: 800;
                color: #f8fafc;
            }
        }

        // Row 1: The PostgreSQL App State Card (Green Accent)
        Rectangle {
            background: #1e293b;
            border-radius: 8px;
            border-width: 2px;
            border-color: #10b981; 
            height: 100px;
            
            VerticalBox {
                padding: 12px;
                Text { text: "📊 PRIMARY STATE ENGINE (POSTGRESQL // SCHEMA: ironvault)"; font-size: 14px; font-weight: 700; color: #10b981; }
                Text { text: "Status: ONLINE // Storing session credentials, access logs, and core verification tokens."; color: #94a3b8; font-size: 13px; }
            }
        }

        // Row 2: Oracle 11g Operations Hub (Cyan Accent)
        Rectangle {
            background: #1e293b;
            border-radius: 8px;
            border-width: 2px;
            border-color: #0ea5e9; 
            
            VerticalBox {
                padding: 15px;
                spacing: 10px;
                Text { text: "🔵 ORACLE 11g OPERATION CONTROL (gpffp, agdak, vlcs)"; font-size: 14px; font-weight: 700; color: #0ea5e9; }
                
                HorizontalBox {
                    spacing: 10px;
                    Text { text: "Schema target:"; color: #e2e8f0; vertical-alignment: center; }
                    input_11g_schema := LineEdit { text: "gpffp"; width: 120px; }
                    Text { text: "Action Type:"; color: #e2e8f0; vertical-alignment: center; }
                    input_11g_action := LineEdit { text: "FETCH_RECORDS"; width: 180px; }
                    
                    Button {
                        text: "Execute 11g Operations";
                        clicked => {
                            root.execute_11g_action(input_11g_schema.text, input_11g_action.text);
                        }
                    }
                }
            }
        }

        // Row 3: Oracle 12c Operations Hub (Purple Accent)
        Rectangle {
            background: #1e293b;
            border-radius: 8px;
            border-width: 2px;
            border-color: #6366f1; 
            
            VerticalBox {
                padding: 15px;
                spacing: 10px;
                Text { text: "🟣 ORACLE 12c DATA HUB (pendak, sai_agartala, penindex)"; font-size: 14px; font-weight: 700; color: #6366f1; }
                
                HorizontalBox {
                    spacing: 10px;
                    Text { text: "Schema target:"; color: #e2e8f0; vertical-alignment: center; }
                    input_12c_schema := LineEdit { text: "pendak"; width: 120px; }
                    Text { text: "Action Type:"; color: #e2e8f0; vertical-alignment: center; }
                    input_12c_action := LineEdit { text: "SYNC_INDEXES"; width: 180px; }
                    
                    Button {
                        text: "Execute 12c Operations";
                        clicked => {
                            root.execute_12c_action(input_12c_schema.text, input_12c_action.text);
                        }
                    }
                }
            }
        }

        // Clean UI element to absorb remaining layout spacing dynamically
        Rectangle {}

        // System Bottom Console Status Monitoring Panel
        Rectangle {
            background: #020617;
            border-radius: 6px;
            height: 50px;
            
            HorizontalBox {
                padding-left: 15px;
                padding-right: 15px;
                Text {
                    text: root.status_text;
                    color: #56b4f8;
                    font-weight: 700;
                    vertical-alignment: center;
                    font-family: "Consolas";
                }
            }
        }
    }
}