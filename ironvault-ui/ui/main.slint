                                        text: "No cryptographic enrolment signals floating on node lanes.";
                                        font-italic: true;
                                        color: Theme.text-muted;
                                        font-size: 15px;
                                    }
                                    if (root.pending_users_list.length > 0): ScrollView {
                                        VerticalLayout {
                                            spacing: 12px;
                                            for p_user in root.pending_users_list: Rectangle {
                                                background: #FFFFFF03;
                                                border-radius: 8px;
                                                border-width: 1px;
                                                border-color: Theme.border-color;
                                                height: 72px;
                                                HorizontalLayout {
                                                    padding: 16px;
                                                    alignment: space-between;
                                                    VerticalLayout {
                                                        spacing: 4px;
                                                        Text {
                                                            text: "OPERATOR IDENTIFICATION INDEX";
                                                            font-size: 10px;
                                                            color: Theme.text-muted;
                                                        }

                                                        Text {
                                                            text: "@" + p_user.username + " (" + p_user.full_name + ")";
                                                            font-size: 16px;
                                                            font-weight: 900;
                                                            color: Theme.brand-primary;
                                                        }
                                                    }

                                                    HorizontalLayout {
                                                        spacing: 12px;
                                                        alignment: LayoutAlignment.center;
                                                        Button {
                                                            icon: @image-url("assets/check-badge.svg");
                                                            clicked => { root.approve_pending_operator(p_user.username, "Operator"); }
                                                        }

                                                        ConfirmButton {
                                                            text: "Deny";
                                                            confirm_text: "Sure?";
                                                            button_height: 32px;
                                                            confirmed => { root.deny_pending_operator(p_user.username); }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        if (root.active_tab == "users"): VerticalLayout {
                            spacing: 24px;
                            vertical-stretch: 1;

                            HorizontalLayout {
                                spacing: 20px;
                                height: 90px;
                                Rectangle {
                                    background: Theme.bg-card;
                                    border-radius: Theme.corner-radius;
                                    border-width: 1px;
                                    border-color: Theme.border-color;
                                    horizontal-stretch: 1;
                                    HorizontalLayout {
                                        padding: 16px;
                                        spacing: 14px;
                                        alignment: start;
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 44px;
                                                height: 44px;
                                                border-radius: 8px;
                                                background: #00E5FF1C;
                                                Image {
                                                    source: @image-url("assets/users.svg");
                                                    width: 20px;
                                                    height: 20px;
                                                    colorize: Theme.brand-primary;
                                                }
                                            }
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            spacing: 2px;
                                            Text {
                                                text: "ACTIVE OPERATORS";
                                                font-size: 11px;
                                                font-weight: 800;
                                                color: Theme.text-muted;
                                            }

                                            Text {
                                                text: root.active_users_list.length == 0 ? "0 Node Links" : (root.active_users_list.length + " Operational");
                                                font-size: 18px;
                                                font-weight: 900;
                                                color: Theme.text-primary;
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    background: Theme.bg-card;
                                    border-radius: Theme.corner-radius;
                                    border-width: 1px;
                                    border-color: Theme.border-color;
                                    horizontal-stretch: 1;
                                    HorizontalLayout {
                                        padding: 16px;
                                        spacing: 14px;
                                        alignment: start;
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 44px;
                                                height: 44px;
                                                border-radius: 8px;
                                                background: #FFB8001C;
                                                Image {
                                                    source: @image-url("assets/radio.svg");
                                                    width: 20px;
                                                    height: 20px;
                                                    colorize: Theme.brand-warning;
                                                }
                                            }
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            spacing: 2px;
                                            Text {
                                                text: "SYSTEM TELEMETRY STATUS";
                                                font-size: 11px;
                                                font-weight: 800;
                                                color: Theme.text-muted;
                                            }

                                            Text {
                                                text: "HANDSHAKE STABLE";
                                                font-size: 16px;
                                                font-weight: 900;
                                                color: Theme.brand-success;
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    background: Theme.bg-card;
                                    border-radius: Theme.corner-radius;
                                    border-width: 1px;
                                    border-color: Theme.border-color;
                                    horizontal-stretch: 1;
                                    HorizontalLayout {
                                        padding: 16px;
                                        spacing: 14px;
                                        alignment: start;
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 44px;
                                                height: 44px;
                                                border-radius: 8px;
                                                background: #FF33661C;
                                                Image {
                                                    source: @image-url("assets/zap.svg");
                                                    width: 20px;
                                                    height: 20px;
                                                    colorize: Theme.brand-danger;
                                                }
                                            }
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            spacing: 2px;
                                            Text {
                                                text: "ENCLAVE ACCESS PROTECTION";
                                                font-size: 11px;
                                                font-weight: 800;
                                                color: Theme.text-muted;
                                            }

                                            Text {
                                                text: "MILITARY-SHIELD";
                                                font-size: 16px;
                                                font-weight: 900;
                                                color: Theme.brand-danger;
                                            }
                                        }
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 24px;
                                vertical-stretch: 1;

                                VerticalLayout {
                                    width: 55%;
                                    spacing: 12px;
                                    Text {
                                        text: "SECURE OPERATOR SUITE LEDGER";
                                        font-size: 11px;
                                        font-weight: 900;
                                        color: Theme.text-muted;
                                        letter-spacing: 0.5px;
                                    }

                                    Rectangle {
                                        background: Theme.bg-sidebar;
                                        border-radius: Theme.corner-radius;
                                        border-width: 1px;
                                        border-color: Theme.border-color;
                                        vertical-stretch: 1;
                                        VerticalLayout {
                                            padding: 12px;
                                            ScrollView {
                                                VerticalLayout {
                                                    spacing: 10px;
                                                    for user in root.active_users_list: Rectangle {
                                                        background: root.lease_target_user == user.username ? #00E5FF11 : Theme.bg-card;
                                                        border-radius: 8px;
                                                        border-width: 1px;
                                                        border-color: root.lease_target_user == user.username ? Theme.brand-primary : Theme.border-color;
                                                        height: 70px;
                                                        HorizontalLayout {
                                                            padding: 14px;
                                                            alignment: space-between;
                                                            VerticalLayout {
                                                                spacing: 4px;
                                                                width: 180px;
                                                                Text {
                                                                    text: user.full_name;
                                                                    font-size: 14px;
                                                                    font-weight: 800;
                                                                    color: Theme.text-primary;
                                                                }

                                                                Text {
                                                                    text: "@" + user.username;
                                                                    font-size: 11px;
                                                                    color: Theme.brand-warning;
                                                                    font-weight: 800;
                                                                }
                                                            }

                                                            VerticalLayout {
                                                                alignment: center;
                                                                width: 120px;
                                                                Rectangle {
                                                                    width: 100px;
                                                                    height: 24px;
                                                                    border-radius: 4px;
                                                                    background: user.role == "SuperAdmin" ? #FF33661C : (user.role == "Operator" ? #00E5FF1C : #FFB8001C);
                                                                    border-width: 1px;
                                                                    border-color: user.role == "SuperAdmin" ? Theme.badge-admin : (user.role == "Operator" ? Theme.badge-operator : Theme.badge-pending);
                                                                    Text {
                                                                        text: user.role;
                                                                        font-size: 11px;
                                                                        font-weight: 900;
                                                                        color: parent.border-color;
                                                                        horizontal-alignment: center;
                                                                        vertical-alignment: center;
                                                                    }
                                                                }
                                                            }

                                                            VerticalLayout {
                                                                spacing: 2px;
                                                                width: 150px;
                                                                alignment: center;
                                                                Text {
                                                                    text: "LEASE EXPIRATION";
                                                                    font-size: 9px;
                                                                    color: Theme.text-muted;
                                                                    font-weight: 800;
                                                                }

                                                                Text {
                                                                    text: user.expires_at;
                                                                    font-size: 12px;
                                                                    font-weight: 700;
                                                                    color: Theme.brand-success;
                                                                }
                                                            }

                                                            VerticalLayout {
                                                                alignment: center;
                                                                Button {
                                                                    text: "Select Configuration";
                                                                    height: 32px;
                                                                    icon: @image-url("assets/cog.svg");
                                                                    clicked => {
                                                                        root.lease_target_user = user.username;
                                                                        root.lease_target_role = user.role;
                                                                        root.lease_target_days = "30";
                                                                        root.lease_target_schemas = user.allowed_schemas;
                                                                        root.request_checkbox_states_fetch(user.username);
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 12px;
                                    Text {
                                        text: "ENCLAVE SECURITY ACCESS CONTROL OVERRIDES";
                                        font-size: 11px;
                                        font-weight: 900;
                                        color: Theme.text-muted;
                                        letter-spacing: 0.5px;
                                    }

                                    Rectangle {
                                        background: Theme.bg-card;
                                        border-radius: Theme.corner-radius;
                                        border-width: 1px;
                                        border-color: root.lease_target_user != "" ? Theme.brand-warning : Theme.border-color;
                                        vertical-stretch: 1;
                                        VerticalLayout {
                                            padding: 24px;
                                            ScrollView {
                                                VerticalLayout {
                                                    spacing: 20px;
                                                    alignment: start;
                                                    if (root.lease_target_user == ""): VerticalLayout {
                                                        alignment: center;
                                                        spacing: 12px;
                                                        height: 350px;
                                                        Text {
                                                            text: "🔒 SECURITY OVERRIDE PANEL LOCKED";
                                                            font-size: 13px;
                                                            font-weight: 900;
                                                            color: Theme.brand-warning;
                                                            horizontal-alignment: TextHorizontalAlignment.center;
                                                        }

                                                        Text {
                                                            text: "Select an operator item from the active database ledger on the left to edit network clearance levels, re-route sections, trigger credential resets, or issue revocations.";
                                                            font-size: 12px;
                                                            color: Theme.text-muted;
                                                            horizontal-alignment: TextHorizontalAlignment.center;
                                                            wrap: word-wrap;
                                                        }
                                                    }

                                                    if (root.lease_target_user != ""): VerticalLayout {
                                                        spacing: 16px;
                                                        HorizontalLayout {
                                                            alignment: LayoutAlignment.space-between;
                                                            Text {
                                                                text: "1. PROFILE METADATA IDENTITY";
                                                                font-size: 11px;
                                                                font-weight: 900;
                                                                color: Theme.brand-primary;
                                                                vertical-alignment: center;
                                                            }

                                                            Rectangle {
                                                                width: 26px;
                                                                height: 26px;
                                                                border-radius: 13px;
                                                                background: close_panel_ta.has-hover ? #FF336622 : transparent;
                                                                Image {
                                                                    source: @image-url("assets/subtract-circle.svg");
                                                                    width: 14px;
                                                                    height: 14px;
                                                                    x: (parent.width - self.width) / 2;
                                                                    y: (parent.height - self.height) / 2;
                                                                    colorize: close_panel_ta.has-hover ? Theme.brand-danger : Theme.text-muted;
                                                                }

                                                                close_panel_ta := TouchArea {
                                                                    clicked => { root.lease_target_user = ""; }
                                                                }
                                                            }
                                                        }

                                                        VerticalLayout {
                                                            spacing: 4px;
                                                            Text {
                                                                text: "TARGET OPERATOR ID TOKEN";
                                                                font-size: 10px;
                                                                font-weight: 800;
                                                                color: Theme.text-muted;
                                                            }

                                                            LineEdit {
                                                                text: "@" + root.lease_target_user;
                                                                enabled: false;
                                                                height: Theme.input-height;
                                                            }
                                                        }

                                                        Rectangle {
                                                            height: 1px;
                                                            background: Theme.border-color;
                                                            opacity: 0.4;
                                                        }

                                                        Text {
                                                            text: "2. WORKSPACE ACCESS PARAMETERS";
                                                            font-size: 11px;
                                                            font-weight: 900;
                                                            color: Theme.brand-primary;
                                                        }

                                                        VerticalLayout {
                                                            spacing: 4px;
                                                            Text {
                                                                text: "SECURITY CLEARANCE CLASS GROUP ROLE";
                                                                font-size: 10px;
                                                                font-weight: 800;
                                                                color: Theme.text-muted;
                                                            }

                                                            LineEdit {
                                                                text <=> root.lease_target_role;
                                                                placeholder_text: "Operator / SuperAdmin";
                                                                height: Theme.input-height;
                                                            }
                                                        }

                                                        VerticalLayout {
                                                            spacing: 4px;
                                                            Text {
                                                                text: "LEASE COMPLIANCE VALIDATION RENEWAL INTERVAL (DAYS)";
                                                                font-size: 10px;
                                                                font-weight: 800;
                                                                color: Theme.text-muted;
                                                            }

                                                            LineEdit {
                                                                text <=> root.lease_target_days;
                                                                placeholder_text: "30";
                                                                height: Theme.input-height;
                                                            }
                                                        }

                                                        VerticalLayout {
                                                            spacing: 6px;
                                                            Text {
                                                                text: "ASSIGN GRANULAR SCHEMA MATRIX PRIVILEGES";
                                                                font-size: 10px;
                                                                font-weight: 800;
                                                                color: Theme.text-muted;
                                                            }

                                                            HorizontalLayout {
                                                                spacing: 16px;
                                                                ToggleAccessCheckbox {
                                                                    text: "gpffp (Payments)";
                                                                    checked <=> root.cb_gpf;
                                                                }

                                                                ToggleAccessCheckbox {
                                                                    text: "vlcs (Vouchers)";
                                                                    checked <=> root.cb_vlcs;
                                                                }

                                                                ToggleAccessCheckbox {
                                                                    text: "sai_agartala (P-SAI)";
                                                                    checked <=> root.cb_sai;
                                                                }

                                                                ToggleAccessCheckbox {
                                                                    text: "pendak (DAK Diary)";
                                                                    checked <=> root.cb_dak;
                                                                }
                                                            }
                                                        }

                                                        HorizontalLayout {
                                                            alignment: LayoutAlignment.end;
                                                            spacing: 12px;
                                                            padding-top: 4px;
                                                            Button {
                                                                icon: @image-url("assets/shield-check-1.svg");
                                                                text: "Save Modification Pass";
                                                                height: 36px;
                                                                clicked => {
                                                                    root.commit_user_settings_pass(
                                                                        root.lease_target_user,
                                                                        root.lease_target_role,
                                                                        root.lease_target_days,
                                                                        root.cb_gpf,
                                                                        root.cb_vlcs,
                                                                        root.cb_sai,
                                                                        root.cb_dak
                                                                    );
                                                                    root.lease_target_user = "";
                                                                }
                                                            }
                                                        }

                                                        Rectangle {
                                                            height: 1px;
                                                            background: Theme.border-color;
                                                            opacity: 0.4;
                                                        }

                                                        Text {
                                                            text: "3. CRITICAL SECURITY OVERRIDES";
                                                            font-size: 11px;
                                                            font-weight: 900;
                                                            color: Theme.brand-danger;
                                                        }

                                                        HorizontalLayout {
                                            spacing: 12px;
                                            alignment: LayoutAlignment.stretch;
                                            ConfirmButton {
                                                text: "🔑 Reset One-Time Access Token";
                                                confirm_text: "Confirm Reset?";
                                                horizontal-stretch: 1;
                                                confirmed => { root.reset_user_password(root.lease_target_user); root.lease_target_user = ""; }
                                            }

                                            ConfirmButton {
                                                text: "🚨 Ban Operator Profile";
                                                confirm_text: "Confirm Ban?";
                                                horizontal-stretch: 1;
                                                confirmed => { root.ban_user(root.lease_target_user); root.lease_target_user = ""; }
                                            }
                                        }

                                        HorizontalLayout {
                                            padding-top: 4px;
                                            ConfirmButton {
                                                text: "🔓 Release Hardware Fingerprint (HWID Unblock)";
                                                confirm_text: "Confirm Release?";
                                                button_height: 36px;
                                                horizontal-stretch: 1;
                                                confirmed => { root.request_hwid_unblock(root.lease_target_user); root.lease_target_user = ""; }
                                            }
                                        }

                                                        Rectangle {
                                                            height: 8px;
                                                        }

                                                        Rectangle {
                                                            height: 1px;
                                                            background: Theme.border-color;
                                                        }

                                                        HorizontalLayout {
                                                            padding-top: 4px;
                                                            Button {
                                                                icon: @image-url("assets/navigation-left.svg");
                                                                text: "Dismiss Panel Focus Configuration";
                                                                height: 34px;
                                                                horizontal-stretch: 1;
                                                                clicked => { root.lease_target_user = ""; }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    if (root.op_status_msg != ""): Rectangle {
                        height: 54px;
                        background: root.op_is_error ? #7F1D1D4A : #064E3B4A;
                        border-width: 1px;
                        border-color: root.op_is_error ? Theme.brand-danger : Theme.brand-success;
                        HorizontalLayout {
                            padding-left: 24px;
                            padding-right: 24px;
                            spacing: 16px;
                            alignment: space-between;
                            Text {
                                text: root.op_status_msg;
                                color: root.op_is_error ? #FCA5A5 : #6EE7B7;
                                font-size: 14px;
                                font-weight: 800;
                                vertical-alignment: center;
                            }

                            VerticalLayout {
                                alignment: center;
                                Button {
                                    text: "Dismiss Notification";
                                    height: 30px;
                                    clicked => { root.op_status_msg = ""; }
                                }
                            }
                        }
                    }
                }
            }
        }

        if (root.forced_password_reset_state): Rectangle {
            background: #05070BD9;
            TouchArea { }

            Rectangle {
                width: 460px;
                height: 380px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                background: Theme.bg-card;
                border-radius: 16px;
                border-width: 2px;
                border-color: Theme.brand-warning;
                drop-shadow-blur: 24px;
                drop-shadow-color: #FFB80040;
                VerticalLayout {
                    width: parent.width;
                    height: parent.height;
                    padding: 32px;
                    spacing: 18px;

                    VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: "🛡️ FORCED CREDENTIAL MITIGATION RECOGNIZED";
                            font-size: 11px;
                            font-weight: 900;
                            color: Theme.brand-warning;
                            horizontal-alignment: TextHorizontalAlignment.center;
                            letter-spacing: 0.5px;
                        }

                        Text {
                            text: "Your session token was generated via a dynamic administrator one-time reset. You must establish a strong custom master password sequence before terminal initialization.";
                            font-size: 12px;
                            color: Theme.text-secondary;
                            horizontal-alignment: TextHorizontalAlignment.center;
                            wrap: word-wrap;
                        }
                    }

                    Rectangle {
                        height: 1px;
                        background: Theme.border-color;
                    }

                    VerticalLayout {
                        spacing: 12px;
                        VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: "NEW MASTER PASSWORD";
                                font-size: 10px;
                                font-weight: 800;
                                color: Theme.text-muted;
                            }

                            LineEdit {
                                text <=> root.form_new_pass;
                                input-type: password;
                                height: Theme.input-height;
                                placeholder_text: "Enter high-entropy sequence";
                            }
                        }

                        VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: "CONFIRM MASTER PASSWORD";
                                font-size: 10px;
                                font-weight: 800;
                                color: Theme.text-muted;
                            }

                            LineEdit {
                                text <=> root.form_confirm_pass;
                                input-type: password;
                                height: Theme.input-height;
                                placeholder_text: "Repeat sequence exactly";
                            }
                        }
                    }

                    if (root.password_reset_error != ""): Text {
                        text: root.password_reset_error;
                        color: Theme.brand-danger;
                        font-size: 12px;
                        font-weight: 800;
                        horizontal-alignment: TextHorizontalAlignment.center;
                    }

                    Button {
                        text: "🔒 Authorize and Update Enclave Key";
                        height: 42px;
                        clicked => {
                            if (root.form_new_pass == "") { root.password_reset_error = "Error: Input cannot be empty."; }
                            else if (root.form_new_pass != root.form_confirm_pass) { root.password_reset_error = "Error: Password confirmation mismatch."; }
                            else { root.commit_forced_password_update(root.current_user_name, root.form_new_pass); }
                        }
                    }
                }
            }
        }

        if (root.show_welcome_popup): Rectangle {
            background: #000000B3;
            TouchArea { }

            Rectangle {
                width: 420px;
                height: 240px;
                background: Theme.bg-card;
                border-radius: 16px;
                border-width: 2px;
                border-color: Theme.brand-primary;
                VerticalLayout {
                    padding: 30px;
                    alignment: space-between;
                    VerticalLayout {
                        spacing: 8px;
                        Text {
                            text: "🔒 SECURE ENCLAVE SESSION ENGAGED";
                            font-size: 11px;
                            font-weight: 900;
                            color: Theme.brand-primary;
                            horizontal-alignment: center;
                            letter-spacing: 1px;
                        }

                        Text {
                            text: "Welcome, " + root.current_user_full_name;
                            font-size: 20px;
                            font-weight: 800;
                            color: Theme.text-primary;
                            horizontal-alignment: TextHorizontalAlignment.center;
                        }

                        Text {
                            text: "Clearance Class: " + root.current_user_role;
                            font-size: 13px;
                            font-weight: 700;
                            color: Theme.brand-warning;
                            horizontal-alignment: TextHorizontalAlignment.center;
                        }
                    }

                    Button {
                        text: "Enter Command Console Node";
                        height: 40px;
                        clicked => { root.show_welcome_popup = false; }
                    }
                }
            }
        }
        if (root.reveal_secret_visible): Rectangle {
            background: #000000CC;
            TouchArea { }

            Rectangle {
                width: 440px;
                height: 220px;
                background: Theme.bg-card;
                border-radius: 16px;
                border-width: 2px;
                border-color: Theme.brand-warning;
                VerticalLayout {
                    padding: 28px;
                    spacing: 14px;

                    Text {
                        text: "🔑 ONE-TIME SECRET — SHOWN ONCE ONLY";
                        font-size: 11px;
                        font-weight: 900;
                        color: Theme.brand-warning;
                        horizontal-alignment: center;
                        letter-spacing: 0.5px;
                    }

                    Text {
                        text: root.reveal_secret_label;
                        font-size: 12px;
                        color: Theme.text-secondary;
                        horizontal-alignment: center;
                    }

                    Rectangle {
                        background: Theme.bg-main;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.border-color;
                        height: 44px;
                        Text {
                            text: root.reveal_secret_value;
                            font-family: "Consolas";
                            font-size: 18px;
                            font-weight: 900;
                            color: Theme.brand-primary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: "This will not be shown again. Deliver it to the operator securely, then dismiss.";
                        font-size: 11px;
                        color: Theme.text-muted;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }

                    Button {
                        text: "I've recorded it — Clear from screen";
                        height: 38px;
                        clicked => {
                            root.reveal_secret_value = "";
                            root.reveal_secret_label = "";
                            root.reveal_secret_visible = false;
                        }
                    }
                }
            }
        }
    }
}
